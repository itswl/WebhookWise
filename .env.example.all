# ============================================================
# WebhookWise full configuration reference
# All settings can be set via the .env file or environment variables
# Static config changes require a service restart to take effect
# ============================================================


# ======================== Server configuration ========================
# Basic runtime parameters: listen address, port, environment, logging

# HTTP listen address. Usually 0.0.0.0 inside a container; 127.0.0.1 for local development
HOST=0.0.0.0

# HTTP listen port
PORT=8000

# Application environment label used in logs and telemetry
# The local Docker Compose startup defaults to overriding it with COMPOSE_APP_ENV
APP_ENV=production
COMPOSE_APP_ENV=development

# Explicit debug switch; APP_ENV does not change it implicitly
DEBUG=false

# Run mode, determines which components the process starts:
#   api       — HTTP service only (receives webhooks + admin API)
#   worker    — background consumer process only (handles AI analysis, forward delivery)
#   scheduler — scheduled task dispatch process only (data cleanup, OpenClaw polling)
RUN_MODE=api

# Application log level: DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# Log level for third-party libraries (SQLAlchemy / httpx / redis etc.) to avoid framework noise
THIRD_PARTY_LOG_LEVEL=WARNING

# ======================== Gunicorn / Uvicorn configuration ========================
# Only takes effect when RUN_MODE=api

# Number of Gunicorn worker processes. Recommended 2-4 * CPU cores, capped by available memory
API_WORKERS=2

# Gunicorn worker timeout (seconds). Increase appropriately for slow requests or time-consuming AI calls
GUNICORN_TIMEOUT=120

# Gunicorn graceful shutdown timeout (seconds). Workers are force-killed after the timeout
GUNICORN_GRACEFUL_TIMEOUT=30

# Recycle each Gunicorn worker after this many requests (0 disables). Bounds
# gradual RSS growth; the jitter staggers restarts so workers don't recycle at once
GUNICORN_MAX_REQUESTS=10000
GUNICORN_MAX_REQUESTS_JITTER=1000

# Uvicorn event loop implementation. uvloop outperforms the default asyncio (requires the uvloop package)
UVICORN_LOOP=uvloop

# Uvicorn HTTP parser. httptools is faster than h11 (requires the httptools package)
UVICORN_HTTP=httptools

# Unique identifier for the worker node (defaults to hostname + PID, usually no need to set manually)
# Note: do not set a fixed value with docker compose --scale worker=N, or consumer names will collide
# WORKER_ID=


# ======================== Payload processing ========================
# Controls compression and async processing strategy for large payloads

# Payloads larger than this byte count are decoded/redacted via asyncio.to_thread() to avoid blocking the event loop
# Default 512KB
PAYLOAD_OFFLOAD_THRESHOLD_BYTES=524288

# Payloads smaller than this byte count skip Zstd compression to save CPU overhead
# Default 4KB
PAYLOAD_COMPRESS_THRESHOLD_BYTES=4096

# Payloads larger than this byte count are decompressed in a thread pool to avoid blocking the event loop
# Default 4KB
PAYLOAD_DECOMPRESS_ASYNC_THRESHOLD_BYTES=4096


# ======================== Security configuration ========================
# Authentication, authorization, rate limiting, security policies

# Shared secret for Webhook HMAC signature verification. Always change it in production.
# Senders must compute the signature with this secret and put it in the X-Webhook-Signature header
WEBHOOK_SECRET=please-change-webhook-secret

# API access key, used for authentication of admin endpoints
API_KEY=please-change-api-key

# Separate API key for admin write operations (config changes, event replay, DDL migrations and other high-risk operations)
ADMIN_WRITE_KEY=please-change-admin-write-key

# Maximum byte count for the Webhook request body. Returns 413 when exceeded
# Default 1MB
MAX_WEBHOOK_BODY_BYTES=1048576

# Whether the HSTS response header includes the includeSubDomains directive
# Only meaningful over HTTPS with a reverse proxy terminating TLS; disabled by default to avoid affecting other services on the same domain
HSTS_INCLUDE_SUBDOMAINS=false

# === Rate limiting ===
# Per-IP request limit per minute. 0 = unlimited
WEBHOOK_RATE_LIMIT_PER_MINUTE=600

# Per-IP burst limit (per 10-second window). 0 = unlimited. Used to prevent instantaneous spikes
WEBHOOK_RATE_LIMIT_BURST=200

# Global total request limit per minute (across all IPs). 0 = unlimited
# Protects backend processing capacity from being saturated by external traffic
WEBHOOK_RATE_LIMIT_GLOBAL_PER_MINUTE=0

# Per-IP per-minute limit for authenticated admin/read APIs (/v1/webhooks, /v1/forward-rules,
# /v1/admin/* etc.). 0 = unlimited. When enabled, it suppresses API key brute-forcing and admin-plane load;
# rate limiting runs before authentication, so failed auth attempts also count. Must be higher than the
# number of requests issued by a single Dashboard load (the Dashboard auto-refreshes every 60s). Fail-open on Redis errors.
ADMIN_API_RATE_LIMIT_PER_MINUTE=300

# Per-resource cooldown for expensive operator actions such as re-analysis, manual forwarding,
# and dead-letter replay. Backed by Redis across all API replicas. 0 = disabled
ADMIN_ACTION_COOLDOWN_SECONDS=60

# Whether to allow requests through when Redis is unavailable (fail-open). true = degrade and allow, false = reject
RATE_LIMIT_FAIL_OPEN_ON_REDIS_ERROR=false

# Whether to enforce webhook authentication. When true, requests without a signature are rejected
REQUIRE_WEBHOOK_AUTH=true

# Whether to enforce replay protection for signed webhooks. When enabled, the upstream must send an x-webhook-timestamp
# header and compute the HMAC-SHA256 signature over "<timestamp>.<body>". Default false for compatibility.
WEBHOOK_REPLAY_PROTECTION_ENABLED=false
# Maximum allowed clock skew for replay protection (seconds)
WEBHOOK_REPLAY_MAX_SKEW_SECONDS=300

# === Proxy trust ===
# Whether to trust the X-Forwarded-For / X-Real-IP headers. Set to true when behind a reverse proxy
TRUST_PROXY_HEADERS=false

# CIDR list of trusted proxies (comma-separated). Only proxy headers from these addresses are honored
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# === Forwarding security ===
# Whether to allow forwarding to localhost / private network / reserved IP addresses. Disabled by default to prevent SSRF
ALLOW_PRIVATE_TARGET_URLS=false

# Allowlist of forward target domains (comma-separated). Supports example.com / .example.com / *.example.com
# Empty = allow all public domains
FORWARD_TARGET_ALLOWLIST=

# === Read-only MCP server ===
# Expose the read-only MCP server at /mcp so MCP-compatible agents can query WebhookWise. Off by default
MCP_ENABLED=false
# Comma-separated Host header values allowed for /mcp (DNS-rebinding protection). localhost/127.0.0.1 always allowed.
# Behind a reverse proxy, add BOTH the bare host and host:port forms, e.g. dejavu.example.com,dejavu.example.com:443
MCP_ALLOWED_HOSTS=
# Comma-separated Origin header values allowed for /mcp; empty = loopback origins only
MCP_ALLOWED_ORIGINS=


# ======================== Redis configuration ========================
# Redis is used for the dedup cache, message queue, distributed locks, and rate-limit counters

# The local full Docker Compose stack uses service DNS: redis.
# When running uvicorn/taskiq directly on the host, change the host to localhost.
REDIS_URL=redis://redis:6379/0

# Redis port exposed to the host by deploy/compose/docker-compose.infra.yml
REDIS_PORT=6379

# Redis socket connect timeout (seconds)
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5

# Redis socket read/write timeout (seconds)
REDIS_SOCKET_TIMEOUT_SECONDS=10

# Redis health check interval (seconds). Periodic PING keep-alive
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30


# ======================== DB configuration ========================
# PostgreSQL connection pool and query behavior

# Connection string. SQLAlchemy async automatically uses the asyncpg driver; no need to add an explicit +asyncpg prefix.
# The local full Docker Compose stack uses service DNS: postgres.
# When running uvicorn/taskiq directly on the host, change the host to localhost.
DATABASE_URL=postgresql://webhook_user:please-change-postgres-password@postgres:5432/webhooks

# The following three are used by Docker Compose when creating the PostgreSQL container; the app itself reads DATABASE_URL
POSTGRES_DB=webhooks
POSTGRES_USER=webhook_user
POSTGRES_PASSWORD=please-change-postgres-password
POSTGRES_PORT=5432

# SQLAlchemy connection pool size. Each worker process maintains its own independent connection pool
DB_POOL_SIZE=5

# Maximum number of overflow connections the pool may create beyond pool_size
DB_MAX_OVERFLOW=5

# Maximum number of seconds a connection stays alive in the pool before being recycled and recreated
DB_POOL_RECYCLE_SECONDS=3600

# Timeout in seconds for acquiring a connection from the pool
DB_POOL_TIMEOUT_SECONDS=30

# PostgreSQL statement timeout (milliseconds). On timeout PG cancels the query, and the pipeline catches the exception and safely retries
# Recommended range 5000-30000; not advisable to go below 5000
DB_STATEMENT_TIMEOUT_MS=30000

# PostgreSQL synchronous_commit setting:
#   on  — default, every commit waits for the WAL flush, safest
#   off — disables synchronous commit, 3-5x write performance gain, but a power loss may lose the last 1-2 seconds of data
#         Acceptable for the Webhook scenario (Redis MQ + raw ingest retry act as a fallback)
DB_SYNC_COMMIT=on


# ======================== DB Backup configuration ========================
# scripts.ops.backup_db uses pg_dump to generate PostgreSQL custom-format backups.
# On success it writes a matching .dump.sha256 checksum file; once S3 is configured, an upload failure returns non-zero.

# Backup output directory. Relative paths are resolved against the project root
BACKUP_DIR=backups

# Local backup retention in days
BACKUP_RETENTION_DAYS=30

# Run interval in seconds for the compose backup service (profile=backup), default 86400 (once per day)
BACKUP_INTERVAL_SECONDS=86400

# Host directory the compose backup service writes backups to (mounted into the container at /backups)
BACKUP_HOST_DIR=./backups

# Whether to enable pg_dump custom-format compression
BACKUP_COMPRESS=true

# Optional: S3 or S3-compatible object storage upload target. Upload is skipped when AWS_BUCKET is empty
AWS_BUCKET=
AWS_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BACKUP_PATH_PREFIX=webhookwise-backups


# ======================== Migration Job configuration ========================
# Startup retry strategy for the database migration container

# Maximum number of database connection retries at migration startup
MIGRATION_DB_MAX_RETRIES=30

# Wait time in seconds between two retries
MIGRATION_DB_RETRY_INTERVAL_SECONDS=2


# ======================== Concurrency control and background tasks ========================

# Background scan interval (seconds). Controls how often OpenClaw polling and forward outbox retries are checked
BACKGROUND_SCAN_INTERVAL_SECONDS=300

# Aggregated metrics refresh interval (seconds). Recommended >= 30
METRICS_REFRESH_INTERVAL_SECONDS=60

# Interval (seconds) at which the TaskIQ Scheduler refreshes the schedule list. Recommended >= 30 in production to avoid overlapping-refresh alerts under low CPU quota
TASKIQ_SCHEDULER_UPDATE_INTERVAL_SECONDS=30

# Loop interval (seconds) at which the TaskIQ Scheduler checks whether tasks need to be dispatched
TASKIQ_SCHEDULER_LOOP_INTERVAL_SECONDS=5

# Retain TaskIQ result records for one hour instead of indefinitely; almost every
# task is fire-and-forget, so a longer TTL only accumulates dead keys and AOF volume
TASKIQ_RESULT_TTL_SECONDS=3600

# Optional dedicated Redis URL for dynamic schedules. Empty derives REDIS_URL database + 1
TASKIQ_SCHEDULE_REDIS_URL=

# Redis SCAN batch size used only in the isolated schedule database
TASKIQ_SCHEDULE_SCAN_BUFFER_SIZE=1000

# Once a forward outbox record is claimed, if it is not completed within this many seconds it is considered stale, allowing other workers to re-claim it
FORWARD_OUTBOX_STALE_SECONDS=300

# Random startup delay for workers (seconds). Staggers slot / pending-message contention when multiple instances restart at once
# 0 = disabled
WORKER_STARTUP_JITTER_SECONDS=0


# ======================== Redis Stream MQ configuration ========================
# The Webhook internal message queue is built on Redis Streams

# Stream name
WEBHOOK_MQ_QUEUE=webhook:queue

# Consumer Group name. Consumers within the same group share consumption
WEBHOOK_MQ_CONSUMER_GROUP=webhook-processors

# Maximum number of messages fetched per XREADGROUP
WEBHOOK_MQ_CONSUMER_BATCH_SIZE=10

# XREADGROUP blocking wait timeout (milliseconds)
WEBHOOK_MQ_CONSUMER_TIMEOUT_MS=1000

# Once a pending message has been idle for more than this many milliseconds, it can be re-claimed by another worker (XCLAIM)
WEBHOOK_MQ_PENDING_IDLE_TIMEOUT_MS=300000

# Maximum stream length (maintained using XTRIM approximate trim)
WEBHOOK_MQ_STREAM_MAXLEN=100000

# Fraction of MAXLEN at which the dashboard/Action Center flags the queue as
# backlogged (visibility only, no request is rejected). Keyed on the UNCONSUMED
# backlog (undelivered lag + un-acked pending), not total stream length — a busy
# stream sits at MAXLEN of already-acked entries. 0 disables the warning.
WEBHOOK_MQ_BACKLOG_WARN_FRACTION=0.8

# Fraction of MAXLEN above which ingress applies backpressure: new webhooks are
# rejected with 503 Retry-After so a retrying upstream holds them, instead of the
# stream silently trimming its oldest un-acked entries. Keyed on the unconsumed
# backlog (lag + pending), not total length. 0 disables (default). Enable only
# after capacity-planning MAXLEN and confirming upstreams retry on 503.
WEBHOOK_MQ_INGRESS_HIGH_WATER_FRACTION=0


# ======================== AI analysis configuration ========================
# Calls an LLM to intelligently analyze alerts

# Master switch. When disabled, no webhook goes through AI and goes straight to rule matching
ENABLE_AI_ANALYSIS=true

# LLM API key
OPENAI_API_KEY=

# LLM API base URL. Any OpenAI-compatible provider works (OpenRouter / Azure / self-hosted)
OPENAI_API_URL=https://openrouter.ai/api/v1

# Model identifier. Fill in according to the model list supported by the provider
OPENAI_MODEL=anthropic/claude-sonnet-4

# instructor structured-output mode (case-insensitive Mode name). Default json is the safest;
# when the upstream provider supports strict schemas you can switch to a stronger mode to reduce bad JSON at the source:
# OpenRouter uses openrouter_structured_outputs; OpenAI natively uses tools_strict or json_schema.
# Unknown/unsupported values safely fall back to json during client initialization.
AI_INSTRUCTOR_MODE=json

# LLM sampling temperature. Lower is more deterministic, higher is more creative. Recommended 0.1-0.3 for alert analysis
OPENAI_TEMPERATURE=0.2

# AI system prompt. Defines the analysis role and behavior
AI_SYSTEM_PROMPT=你是一个专业的 DevOps 和系统运维专家...

# Overall timeout for AI requests (seconds)
AI_HTTP_TIMEOUT_SECONDS=60.0

# AI request connect timeout (seconds)
AI_HTTP_CONNECT_TIMEOUT_SECONDS=10.0

# === Prompt templates ===
# Path to the user prompt file (relative to the project root)
AI_USER_PROMPT_FILE=prompts/webhook_analysis_detailed.txt
# Inline user prompt (overrides the file when non-empty)
AI_USER_PROMPT=

# Path to the deep-analysis prompt file
DEEP_ANALYSIS_PROMPT_FILE=prompts/deep_analysis.txt
# Inline deep-analysis prompt (overrides the file when non-empty)
DEEP_ANALYSIS_PROMPT=

# Incident summary prompt; kept in Chinese so the generated report stays Chinese.
INCIDENT_SUMMARY_PROMPT_FILE=prompts/incident_summary.txt
INCIDENT_SUMMARY_PROMPT=

# === AI degradation ===
# When enabled, automatically degrade to rule matching if the AI service is unavailable (timeout / rate limit / error)
# When disabled, an AI failure raises an error directly
ENABLE_AI_DEGRADATION=true

# === Payload preprocessing ===
# Maximum byte count of the payload sent to AI. Truncated when exceeded to control token consumption
AI_PAYLOAD_MAX_BYTES=32768

# Keys stripped from the payload before sending to AI (comma-separated), to reduce noise and tokens
AI_PAYLOAD_STRIP_KEYS=images,raw_trace,stacktrace,base64_data,screenshot,binary_data

# === Keyword rules ===
# Keywords that trigger the high severity level (comma-separated, matched against AI analysis results)
RULE_HIGH_KEYWORDS=error,failure,critical,alert,错误,失败,故障

# Keywords that trigger the warning severity level
RULE_WARN_KEYWORDS=warning,warn,警告

# Keywords that identify metric-type alerts (e.g. QPS, CPU, memory, etc.)
RULE_METRIC_KEYWORDS=4xxqps,5xxqps,error,cpu,memory,disk

# Threshold amplification factor. Raises the severity level when the alert value exceeds the threshold by N times
RULE_THRESHOLD_MULTIPLIER=4.0

# Tiered AI routing: when enabled, alerts judged low-value by rules skip the (paid) LLM and get a rule-based conclusion directly, concentrating the AI budget on alerts that need it. Disabled by default (= unchanged behavior)
AI_ROUTING_ENABLED=false
# Which rule importance levels skip the LLM (comma-separated, default only low)
AI_ROUTING_SKIP_IMPORTANCE=low

# === Cache and cost ===
# Cache switch for AI analysis results. When enabled, identical alerts reuse the previous analysis result
CACHE_ENABLED=true

# Cache TTL (seconds). Duplicate alerts within 6 hours reuse the analysis directly without calling AI
ANALYSIS_CACHE_TTL_SECONDS=21600

# Cost per 1K input tokens (USD), used for reporting statistics
AI_COST_PER_1K_INPUT_TOKENS=0.003

# Cost per 1K output tokens (USD)
AI_COST_PER_1K_OUTPUT_TOKENS=0.015


# ======================== Knowledge base (RAG) configuration ========================
# Inject relevant internal docs/runbooks into AI analysis. Off by default; enable
# after ingesting documents (POST /v1/admin/kb/documents or scripts/kb_seed.py).
KB_ENABLED=false

# Dedicated embeddings endpoint (OpenAI-compatible /embeddings). Leave blank to use
# a deterministic local placeholder embedding (pipeline runs/tests end to end, but
# retrieval is non-semantic). Configured separately from OPENAI_API_URL so the
# embedding model can differ from the chat model — but may point at the same
# provider. E.g. OpenRouter now exposes /embeddings, so you can reuse your
# OpenRouter key:
#   KB_EMBEDDING_API_URL=https://openrouter.ai/api/v1
#   KB_EMBEDDING_MODEL=qwen/qwen3-embedding-8b   (KB_VECTOR_DIM=4096)
KB_EMBEDDING_API_URL=
KB_EMBEDDING_API_KEY=
KB_EMBEDDING_MODEL=text-embedding-3-small

# Embedding vector dimension (must match the embedding model's output, and the
# placeholder dimension when switching backends — re-ingest if you change it).
# E.g. 256 placeholder / 1536 text-embedding-3-small / 4096 qwen3-embedding-8b.
KB_VECTOR_DIM=256

# Retrieval: how many chunks to inject, and the minimum cosine score to qualify.
KB_TOP_K=3
KB_MIN_SCORE=0.3
# Bound the in-process cosine ranking candidate set.
KB_MAX_CANDIDATES=1000

# Ingestion chunk size (chars) and the max total chars of injected context.
KB_CHUNK_MAX_CHARS=800
KB_MAX_CONTEXT_CHARS=2000

# Embeddings HTTP timeout (seconds)
KB_EMBEDDING_TIMEOUT_SECONDS=30.0


# ======================== Noise reduction configuration ========================
# Identifies and suppresses correlated alert storms caused by the same root cause

# Noise reduction master switch
ENABLE_ALERT_NOISE_REDUCTION=true

# Time window (minutes). Alerts within this window participate in correlation analysis
NOISE_REDUCTION_WINDOW_MINUTES=5

# Minimum confidence for determining a root-cause alert (0-1). Alerts above this score are marked as root cause
ROOT_CAUSE_MIN_CONFIDENCE=0.65

# Minimum confidence for two alerts to be considered correlated
NOISE_RELATED_MIN_CONFIDENCE=0.35

# === Noise reduction weights (five-dimension scoring, no normalization needed) ===
# Alert source similarity weight
NOISE_SOURCE_WEIGHT=0.15

# Resource similarity weight (most important dimension, e.g. same host, same cluster)
NOISE_RESOURCE_WEIGHT=0.45

# Semantic similarity weight (similarity of AI-analyzed event descriptions)
NOISE_SEMANTIC_WEIGHT=0.25

# Severity level similarity weight
NOISE_SEVERITY_WEIGHT=0.10

# Time proximity weight
NOISE_TIME_WEIGHT=0.20

# Severity downgrade threshold score. The severity of derived alerts may be lowered
NOISE_SEVERITY_DOWNGRADE_SCORE=0.03

# Whether to suppress forwarding of derived alerts (forward only root-cause alerts)
SUPPRESS_DERIVED_ALERT_FORWARD=true


# ======================== Retry / dedup / notification strategy ========================

# === Alert deduplication ===
# Dedup sliding window (seconds). Alerts with the same fingerprint within this time are grouped as one and no new record is created
# Default 4 hours. The window restarts from last_seen_at each time a duplicate webhook is received
DEDUP_WINDOW_SECONDS=14400

# AI analysis reuse window (seconds). After the dedup window passes, within this time a new alert is created but the AI analysis is reused (no extra token consumption)
# Default 12 hours. The relationship between the two windows:
#   0 - DEDUP_WINDOW          → REUSE (same alert, no AI call)
#   DEDUP_WINDOW - this value → RECHAIN (new alert, reuse AI analysis)
#   beyond this value          → NEW (brand-new alert, brand-new AI analysis)
ANALYSIS_REUSE_WINDOW_SECONDS=43200

# === Periodic reminder ===
# Whether to periodically re-send a notification while the same alert persists
ENABLE_PERIODIC_REMINDER=true

# Periodic reminder interval (hours). Notifies again after the last notification is older than this time
REMINDER_INTERVAL_HOURS=6

# Notification cooldown for duplicate alerts (seconds). Minimum interval between two notifications for the same alert
NOTIFICATION_COOLDOWN_SECONDS=60

# === Alert storm backpressure ===
# Whether to enable the Redis-based distributed processing lock
PROCESSING_LOCK_DISTRIBUTED_ENABLED=true

# Distributed lock TTL (seconds). The lock is released automatically when processing time exceeds this value
PROCESSING_LOCK_TTL_SECONDS=180

# Maximum timeout for acquiring the lock (seconds)
PROCESSING_LOCK_WAIT_TIMEOUT_SECONDS=15

# Polling interval while waiting for the lock (milliseconds)
PROCESSING_LOCK_POLL_INTERVAL_MS=100

# Backpressure fail-fast threshold. New requests are dropped directly when the same alert_hash exceeds this count within the window
PROCESSING_LOCK_FAILFAST_THRESHOLD=20

# Time window for fail-fast counting (seconds)
PROCESSING_LOCK_FAILFAST_WINDOW_SECONDS=10

# Whether the backpressure check allows requests through when Redis is unavailable (fail-open)
INGRESS_BACKPRESSURE_FAIL_OPEN_ON_REDIS_ERROR=false

# === Webhook processing retries ===
# Maximum number of retries when webhook processing fails (non-business errors)
WEBHOOK_RETRY_MAX_RETRIES=5

# Wait seconds for the first retry
WEBHOOK_RETRY_INITIAL_DELAY_SECONDS=30

# Upper bound for retry wait (seconds)
WEBHOOK_RETRY_MAX_DELAY_SECONDS=900

# Exponential backoff multiplier. delay = min(initial * multiplier^n, max_delay)
WEBHOOK_RETRY_BACKOFF_MULTIPLIER=2.0

# === Forward Outbox retries ===
# Maximum number of retries after a forward delivery fails
FORWARD_RETRY_MAX_RETRIES=3

# Wait seconds for the first forward retry
FORWARD_RETRY_INITIAL_DELAY_SECONDS=60

# Upper bound for forward retry wait (seconds)
FORWARD_RETRY_MAX_DELAY_SECONDS=3600

# Exponential backoff multiplier for forward retries
FORWARD_RETRY_BACKOFF_MULTIPLIER=2.0

# Maximum lifetime of a forward intent (seconds). After this it is marked expired and the stale alert is no longer sent
# 0 = disable expiration protection
FORWARD_MAX_DELIVERY_AGE_SECONDS=1800


# ======================== Forwarding configuration ========================
# Behavior for forwarding alerts to external systems (Feishu, custom webhooks, etc.)

# HTTP request timeout for a single forward (seconds)
FORWARD_TIMEOUT_SECONDS=10


# ======================== Feishu integration ========================

# Webhook URL to send deep-analysis results to Feishu
DEEP_ANALYSIS_FEISHU_WEBHOOK=

# HTTP request timeout for the Feishu webhook (seconds)
FEISHU_WEBHOOK_TIMEOUT_SECONDS=10

# Feishu notification cooldown when the AI service errors (seconds). Avoids frequent bombardment
AI_ERROR_NOTIFICATION_COOLDOWN_SECONDS=3600
DASHBOARD_PUBLIC_URL=

# Alert-health digest (cost + noise summary). Aggregates existing AIUsageLog +
# webhook_events and sends one Feishu card. Three independent cadences, all off
# by default. Cron is evaluated in the container timezone (Asia/Shanghai).
# Each cadence's webhook falls back to WEEKLY_REPORT_FEISHU_WEBHOOK, then DEEP_ANALYSIS_FEISHU_WEBHOOK.

# Daily report (default every day 09:00, trailing 1 day)
DAILY_REPORT_ENABLED=false
DAILY_REPORT_CRON=0 9 * * *
DAILY_REPORT_WINDOW_DAYS=1
DAILY_REPORT_FEISHU_WEBHOOK=
DAILY_REPORT_ONLY_ON_ACTIVITY=true

# Weekly report (default every Monday 09:00, trailing 7 days)
WEEKLY_REPORT_ENABLED=false
WEEKLY_REPORT_CRON=0 9 * * 1
WEEKLY_REPORT_WINDOW_DAYS=7
# Dedicated Feishu webhook for the weekly report (falls back to DEEP_ANALYSIS_FEISHU_WEBHOOK when empty)
WEEKLY_REPORT_FEISHU_WEBHOOK=

# Monthly report (default 1st of month 09:00, trailing 30 days)
MONTHLY_REPORT_ENABLED=false
MONTHLY_REPORT_CRON=0 9 1 * *
MONTHLY_REPORT_WINDOW_DAYS=30
MONTHLY_REPORT_FEISHU_WEBHOOK=

# AI cost budget alert: push one Feishu card per month when month-to-date AI
# spend crosses AI_COST_MONTHLY_BUDGET_USD * AI_COST_BUDGET_ALERT_THRESHOLD.
# Checked by the daily report task; 0 = disabled. Webhook falls back to the
# daily report webhook, then the deep-analysis webhook.
AI_COST_MONTHLY_BUDGET_USD=0.0
AI_COST_BUDGET_ALERT_THRESHOLD=0.8
AI_COST_BUDGET_FEISHU_WEBHOOK=


# ======================== OpenClaw configuration ========================
# OpenClaw deep-analysis engine integration

# OpenClaw master switch
OPENCLAW_ENABLED=false

# Deep-analysis platform selection: openclaw
DEEP_ANALYSIS_PLATFORM=openclaw

# OpenClaw Gateway API URL
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18900

# Gateway authentication token
OPENCLAW_GATEWAY_TOKEN=

# Hooks callback verification token
OPENCLAW_HOOKS_TOKEN=

# OpenClaw HTTP API URL
OPENCLAW_HTTP_API_URL=http://127.0.0.1:8085

# Overall timeout for a single deep-analysis task (seconds). Default 15 minutes
OPENCLAW_TIMEOUT_SECONDS=900

# === Polling strategy ===
# How many consecutive times the analysis result must be stable (content unchanged) before it is considered complete
OPENCLAW_STABILITY_REQUIRED_HITS=2

# Delay for the first poll after submitting the analysis (seconds)
OPENCLAW_POLL_INITIAL_DELAY_SECONDS=10

# Upper bound for the polling interval (seconds). Backoff will not exceed this value
OPENCLAW_POLL_MAX_DELAY_SECONDS=120

# Exponential backoff multiplier for polling
OPENCLAW_POLL_BACKOFF_MULTIPLIER=2.0

# Number of consecutive errors before the circuit breaker trips
OPENCLAW_MAX_CONSECUTIVE_ERRORS=8

# Whether to degrade when OpenClaw is unavailable (skip deep analysis and continue processing)
OPENCLAW_ENABLE_DEGRADATION=false

# === Timeouts ===
# HTTP connect timeout (seconds)
OPENCLAW_CONNECT_TIMEOUT_SECONDS=20

# Device authentication nonce generation timeout (seconds)
OPENCLAW_NONCE_TIMEOUT_SECONDS=5

# HTTP request timeout for a single poll (seconds)
OPENCLAW_POLL_TIMEOUT_SECONDS=180

# Retention time of the polling stability state in Redis (seconds)
OPENCLAW_POLL_STABILITY_TTL_SECONDS=3600

# How many frames WebSocket chat.history reads at most before deciding there is no response
OPENCLAW_WS_MAX_HISTORY_FRAMES=50

# === Device Auth ===
# Device authentication ID
OPENCLAW_DEVICE_ID=

# Device authentication private key in PEM format
OPENCLAW_DEVICE_PRIVATE_KEY_PEM=

# Pre-configured device token (alternative to private-key authentication)
OPENCLAW_DEVICE_TOKEN=


# ======================== Circuit Breaker configuration ========================
# Circuit breaker: automatically stops calls to external services after consecutive failures, periodically probing for recovery

# Number of consecutive Feishu webhook failures before the circuit breaker trips
CIRCUIT_BREAKER_FEISHU_THRESHOLD=5

# How many seconds to wait after the Feishu breaker trips before entering half-open state (allowing one probe request)
CIRCUIT_BREAKER_FEISHU_TIMEOUT_SECONDS=30.0

# Number of consecutive OpenClaw failures before the circuit breaker trips
CIRCUIT_BREAKER_OPENCLAW_THRESHOLD=5

# Wait seconds for OpenClaw breaker recovery
CIRCUIT_BREAKER_OPENCLAW_TIMEOUT_SECONDS=30.0

# Number of consecutive forward-target failures before the circuit breaker trips
CIRCUIT_BREAKER_FORWARD_THRESHOLD=5

# Wait seconds for forward-target breaker recovery
CIRCUIT_BREAKER_FORWARD_TIMEOUT_SECONDS=30.0

# Number of consecutive LLM (primary AI analysis) failures before the circuit breaker trips; while tripped, alerts degrade directly to rule-based analysis
CIRCUIT_BREAKER_LLM_THRESHOLD=5
# Wait seconds for LLM breaker recovery
CIRCUIT_BREAKER_LLM_TIMEOUT_SECONDS=30.0


# ======================== Data maintenance / retention policy ========================
# Automatically cleans up expired alert data

# Periodic cleanup master switch
ENABLE_DATA_CLEANUP=true

# Default data retention in days
DATA_RETENTION_DAYS_DEFAULT=30

# Retention-days overrides by alert importance level (JSON object)
# high=90 days, medium=30 days, low=7 days, unknown=3 days
RETENTION_POLICIES={"high":90,"medium":30,"low":7,"unknown":3}

# Retention-days overrides by alert source (JSON object)
SOURCE_RETENTION_POLICIES={"prometheus":30,"grafana":30,"datadog":30}

# Cleanup classification keywords (JSON object). Alerts matching these keywords may be cleaned up sooner
CLEANUP_KEYWORDS={"summary":["一般事件:","测试告警"],"parsed_data":["一般事件"]}

# Delete archived payload snapshots after this many days
ARCHIVE_RETENTION_DAYS=90

# Delete sent/exhausted/expired delivery records after this many days
TERMINAL_OUTBOX_RETENTION_DAYS=30

# Retain AI usage and cost history for this many days
AI_USAGE_RETENTION_DAYS=90

# Resolve quiet incidents automatically after this many days
INCIDENT_AUTO_CLOSE_DAYS=7

# Hour of day to run the cleanup task (hour, 0-23)
MAINTENANCE_HOUR=3


# ======================== OpenTelemetry configuration ========================
# Unified collection of distributed traces, metrics, and logs

# OTel master switch. When disabled, no trace/metric/log is reported
OTEL_ENABLED=false

# === Resource identity ===
# Service name, identifies the source service in trace/metric/log
OTEL_SERVICE_NAME=webhookwise

# Service namespace, used to distinguish service families with the same name
OTEL_SERVICE_NAMESPACE=webhookwise

# Service version. Priority: OTEL_SERVICE_VERSION > SERVICE_VERSION > APP_VERSION
OTEL_SERVICE_VERSION=3.3.0
SERVICE_VERSION=
APP_VERSION=3.3.0

# Deployment environment identifier. Priority: OTEL_DEPLOYMENT_ENVIRONMENT > APP_ENV
OTEL_DEPLOYMENT_ENVIRONMENT=production

# Service instance ID. Used to distinguish instances in multi-instance deployments. Priority: OTEL_SERVICE_INSTANCE_ID > SERVICE_INSTANCE_ID
OTEL_SERVICE_INSTANCE_ID=
SERVICE_INSTANCE_ID=

# OTel semantic convention / schema version. Change this explicitly when upgrading the semantic conventions
OTEL_SEMCONV_VERSION=1.41.0
OTEL_SCHEMA_URL=https://opentelemetry.io/schemas/1.41.0

# === Trace control ===
# Whether to output traces to the console (for debugging)
OTEL_CONSOLE_EXPORTER=false

# Whether to generate traces for the healthcheck endpoints (/live, /ready)
OTEL_INCLUDE_HEALTHCHECKS=false

# URL paths that do not generate traces (comma-separated)
OTEL_EXCLUDED_URLS=/live,/ready,/static

# === OTLP Exporter ===
# Unified endpoint. When set, traces/metrics/logs are all sent here
OTEL_EXPORTER_OTLP_ENDPOINT=

# Set endpoints per signal individually (takes priority over the unified endpoint)
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=

# Export protocol: grpc or http/protobuf
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# OTLP request headers (comma-separated key=value), used for authentication
OTEL_EXPORTER_OTLP_HEADERS=

# OTLP request timeout (seconds)
OTEL_EXPORTER_OTLP_TIMEOUT=10

# Whether to use an unencrypted gRPC connection (development/internal-network use only)
OTEL_EXPORTER_OTLP_INSECURE=false

# === Log export ===
# Whether to export application logs via OTLP
OTEL_LOGS_ENABLED=true

# Whether to create and export traces. Disable in the compact metrics/logs stack
OTEL_TRACES_ENABLED=true

# === Sampling ===
# HTTP semantic convention stability opt-in
OTEL_SEMCONV_STABILITY_OPT_IN=http

# Trace sampling strategy. Recommended parentbased_traceidratio in production; always_on can be set in development
OTEL_TRACES_SAMPLER=parentbased_traceidratio

# Sampling ratio (0-1). 0.1 = 10% of requests are sampled
OTEL_TRACES_SAMPLER_ARG=0.1

# === Cardinality protection ===
# Maximum number of time series for Gauge metrics, preventing memory bloat from high-cardinality attributes
WEBHOOKWISE_GAUGE_SERIES_LIMIT=512

# MetricReader export interval and timeout (milliseconds)
OTEL_METRIC_EXPORT_INTERVAL=60000
OTEL_METRIC_EXPORT_TIMEOUT=30000

# Histogram exemplar filter strategy. trace_based lets traced samples jump from a Grafana metric point to Tempo
OTEL_METRICS_EXEMPLAR_FILTER=trace_based

# Maximum number of distinct webhook.source label values; values beyond it are grouped into "other"
WEBHOOKWISE_SOURCE_LABEL_LIMIT=128


# ======================== Pyroscope / Profiles configuration ========================
# Continuous performance profiling (CPU / memory flame graphs)

# Profiling master switch. Enabled if either of the two is true
PYROSCOPE_ENABLED=false
OTEL_PROFILES_ENABLED=false

# Whether to enable span-to-profile correlation (jump from a trace to the profile at the corresponding moment)
PYROSCOPE_SPAN_PROFILES_ENABLED=true

# Application name. Uses OTEL_SERVICE_NAME when empty
PYROSCOPE_APPLICATION_NAME=

# Pyroscope server address. PYROSCOPE_SERVER_ADDRESS takes priority, PYROSCOPE_URL is the fallback
PYROSCOPE_SERVER_ADDRESS=
PYROSCOPE_URL=

# Sample rate (samples per second)
PYROSCOPE_SAMPLE_RATE=100

# Collect only on-CPU time
PYROSCOPE_ONCPU=true

# Collect only threads holding the GIL (Python-specific, reduces noise)
PYROSCOPE_GIL_ONLY=true

# Whether to enable Pyroscope client library logging
PYROSCOPE_ENABLE_LOGGING=false

# Custom tags (comma-separated key=value)
PYROSCOPE_TAGS=

# Bearer Token authentication
PYROSCOPE_AUTH_TOKEN=

# Basic Auth authentication
PYROSCOPE_BASIC_AUTH_USERNAME=
PYROSCOPE_BASIC_AUTH_PASSWORD=

# Multi-tenant ID
PYROSCOPE_TENANT_ID=


# ======================== Observability Query CLI / MCP configuration ========================
# Used by the diagnostic scripts under scripts/observability/ and the MCP service

# Query mode: direct=access each service directly, grafana-proxy=query via the Grafana API proxy
WEBHOOKWISE_QUERY_MODE=direct

# Address of each service
WEBHOOKWISE_PROMETHEUS_URL=http://localhost:9090
WEBHOOKWISE_LOKI_URL=http://localhost:3100
WEBHOOKWISE_TEMPO_URL=http://localhost:3200
WEBHOOKWISE_GRAFANA_URL=http://localhost:3000
WEBHOOKWISE_PYROSCOPE_URL=http://localhost:4040
WEBHOOKWISE_ALLOY_URL=http://localhost:12345
WEBHOOKWISE_API_URL=http://localhost:8000

# Grafana authentication (Basic Auth or Token, Token takes priority)
WEBHOOKWISE_GRAFANA_USER=admin
WEBHOOKWISE_GRAFANA_PASSWORD=admin
WEBHOOKWISE_GRAFANA_TOKEN=

# UID of each data source in Grafana
WEBHOOKWISE_PROMETHEUS_DATASOURCE_UID=prometheus
WEBHOOKWISE_LOKI_DATASOURCE_UID=loki
WEBHOOKWISE_TEMPO_DATASOURCE_UID=tempo
WEBHOOKWISE_PYROSCOPE_DATASOURCE_UID=pyroscope
WEBHOOKWISE_DIAGNOSTICS_ENABLED=false

# HTTP request User-Agent
WEBHOOKWISE_HTTP_USER_AGENT=WebhookWise-Observability/0.1

# Run ID for the smoke test (auto-generated when left empty)
WEBHOOKWISE_SMOKE_RUN_ID=

# How many seconds the smoke test waits after sending a webhook before checking metrics
WEBHOOKWISE_SMOKE_WAIT_SECONDS=8


# ======================== Local Observability Stack ========================
# Image versions for the Docker Compose observability stack (only affects deploy/compose/docker-compose.observability.yml)

ALERTMANAGER_IMAGE=prom/alertmanager:v0.27.0
ALLOY_IMAGE=grafana/alloy:v1.5.1
BEYLA_IMAGE=grafana/beyla:3.14.0
K6_IMAGE=grafana/k6:0.55.0
LOKI_IMAGE=grafana/loki:3.2.1
PROMETHEUS_IMAGE=prom/prometheus:v2.55.1
TEMPO_IMAGE=grafana/tempo:2.6.1
PYROSCOPE_IMAGE=grafana/pyroscope:1.9.0
GRAFANA_IMAGE=grafana/grafana:11.3.0

# Grafana administrator account
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Faro receiver port (frontend RUM data)
FARO_RECEIVER_PORT=12347

# Target address for the K6 load-test scripts
K6_BASE_URL=http://webhook-service:8000
K6_RUN_ID=
