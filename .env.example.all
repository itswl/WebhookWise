# ============================================================
# WebhookWise 全量配置参考
# 所有配置均可通过 .env 文件或环境变量设置
# 静态配置修改后需重启服务生效
# ============================================================


# ======================== Server 配置 ========================
# 服务运行的基础参数：监听地址、端口、环境、日志

# HTTP 监听地址。容器内通常 0.0.0.0，本地开发可用 127.0.0.1
HOST=0.0.0.0

# HTTP 监听端口
PORT=8000

# 应用环境：development 会自动开启 DEBUG、显示详细错误页
# Docker Compose 本地启动默认使用 COMPOSE_APP_ENV 覆盖
APP_ENV=production
COMPOSE_APP_ENV=development

# 显式调试开关。不设时由 APP_ENV=development 自动推导为 true
DEBUG=false

# 运行模式，决定进程启动哪些组件：
#   api       — 仅 HTTP 服务（接收 webhook + 管理 API）
#   worker    — 仅后台消费进程（处理 AI 分析、转发投递）
#   scheduler — 仅定时任务投递进程（数据清理、OpenClaw 轮询）
RUN_MODE=api

# 应用日志级别：DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# 第三方库（SQLAlchemy / httpx / redis 等）的日志级别，避免框架噪音
THIRD_PARTY_LOG_LEVEL=WARNING

# 本地数据存储目录（原始 payload 等大文件）
DATA_DIR=webhooks_data


# ======================== Gunicorn / Uvicorn 配置 ========================
# 仅 RUN_MODE=api 时生效

# Gunicorn worker 进程数。建议 2-4 * CPU 核数，上限受内存约束
API_WORKERS=4

# Gunicorn worker 超时（秒）。处理慢请求或 AI 调用耗时时需适当调大
GUNICORN_TIMEOUT=120

# Gunicorn 优雅关闭超时（秒）。超时后强制 kill worker
GUNICORN_GRACEFUL_TIMEOUT=30

# Uvicorn 事件循环实现。uvloop 性能优于默认 asyncio（需安装 uvloop 包）
UVICORN_LOOP=uvloop

# Uvicorn HTTP 解析器。httptools 比 h11 更快（需安装 httptools 包）
UVICORN_HTTP=httptools

# Worker 节点唯一标识（默认取 hostname + PID，一般不需要手动设置）
# 注意：docker compose --scale worker=N 时不要设固定值，否则 consumer 名称冲突
# WORKER_ID=


# ======================== Payload 处理 ========================
# 控制大 payload 的压缩和异步处理策略

# 超过此字节数的 payload 解码/脱敏将使用 asyncio.to_thread() 执行，避免阻塞事件循环
# 默认 512KB
PAYLOAD_OFFLOAD_THRESHOLD_BYTES=524288

# 低于此字节数的 payload 不做 Zstd 压缩，节省 CPU 开销
# 默认 4KB
PAYLOAD_COMPRESS_THRESHOLD_BYTES=4096

# 超过此字节数的 payload 解压将卸载到线程池，避免阻塞事件循环
# 默认 4KB
PAYLOAD_DECOMPRESS_ASYNC_THRESHOLD_BYTES=4096


# ======================== Security 配置 ========================
# 认证、鉴权、限流、安全策略

# Webhook HMAC 签名验证的共享密钥。生产环境务必更换
# 发送方需用此密钥计算签名并放入 X-Webhook-Signature 头
WEBHOOK_SECRET=please-change-webhook-secret

# API 访问密钥，用于管理端点的身份验证
API_KEY=please-change-api-key

# Admin 写操作的独立 API Key（修改配置、重放事件、DDL 迁移等高危操作）
ADMIN_WRITE_KEY=please-change-admin-write-key

# Webhook 请求体的最大字节数。超限返回 413
# 默认 1MB
MAX_WEBHOOK_BODY_BYTES=1048576

# HSTS 响应头是否包含 includeSubDomains 指令
# 仅在 HTTPS 且有反向代理终止 TLS 时有意义；默认关闭避免误伤同域名其他服务
HSTS_INCLUDE_SUBDOMAINS=false

# === 限流 ===
# 单 IP 每分钟请求上限。0 = 不限
WEBHOOK_RATE_LIMIT_PER_MINUTE=600

# 单 IP 突发上限（每 10 秒窗口）。0 = 不限。用于防止瞬间洪峰
WEBHOOK_RATE_LIMIT_BURST=200

# 全局每分钟总请求上限（跨所有 IP）。0 = 不限
# 保护后端处理能力不被外部流量打满
WEBHOOK_RATE_LIMIT_GLOBAL_PER_MINUTE=0

# Redis 不可用时是否放行请求（fail-open）。true = 降级放行，false = 拒绝
RATE_LIMIT_FAIL_OPEN_ON_REDIS_ERROR=true

# 是否强制要求 webhook 鉴权。true 时未带签名的请求将被拒绝
REQUIRE_WEBHOOK_AUTH=true

# === 代理信任 ===
# 是否信任 X-Forwarded-For / X-Real-IP 头。在反向代理后面时需设为 true
TRUST_PROXY_HEADERS=false

# 可信代理的 CIDR 列表（逗号分隔）。仅来自这些地址的代理头会被采信
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# === 转发安全 ===
# 是否允许转发到 localhost / 内网 / 保留 IP 地址。默认禁止防止 SSRF
ALLOW_PRIVATE_TARGET_URLS=false

# 转发目标域名白名单（逗号分隔）。支持 example.com / .example.com / *.example.com
# 空 = 允许所有公网域名
FORWARD_TARGET_ALLOWLIST=


# ======================== Redis 配置 ========================
# Redis 用于去重缓存、消息队列、分布式锁、限流计数

REDIS_URL=redis://localhost:6379/0

# Redis Socket 连接超时（秒）
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Redis Socket 读写超时（秒）
REDIS_SOCKET_TIMEOUT=10

# Redis 健康检查间隔（秒）。定期 PING 保活
REDIS_HEALTH_CHECK_INTERVAL=30


# ======================== DB 配置 ========================
# PostgreSQL 连接池与查询行为

# 连接串。SQLAlchemy async 会自动使用 asyncpg 驱动，无需显式加 +asyncpg 前缀
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/webhooks

# 以下三项供 Docker Compose 创建 PostgreSQL 容器时使用，应用本身读 DATABASE_URL
POSTGRES_DB=webhooks
POSTGRES_USER=webhook_user
POSTGRES_PASSWORD=postgres

# SQLAlchemy 连接池大小。每个 worker 进程各自维护一个独立连接池
DB_POOL_SIZE=5

# 连接池允许超过 pool_size 的最大溢出连接数
DB_MAX_OVERFLOW=5

# 连接在池中存活的最大秒数，之后被回收重建
DB_POOL_RECYCLE=3600

# 从连接池获取连接的超时秒数
DB_POOL_TIMEOUT=30

# PostgreSQL 语句超时（毫秒）。超时后 PG 自动取消查询，pipeline 捕获异常并安全重试
# 推荐范围 5000-30000，不建议低于 5000
DB_STATEMENT_TIMEOUT_MS=30000

# PostgreSQL synchronous_commit 设置：
#   on  — 默认，每次提交都等 WAL 刷盘，最安全
#   off — 关闭同步提交，写入性能提升 3-5x，但断电可能丢失最近 1-2 秒数据
#         Webhook 场景可接受（有 Redis MQ + raw ingest 重试兜底）
DB_SYNC_COMMIT=on


# ======================== Migration Job 配置 ========================
# 数据库迁移容器的启动重试策略

# 迁移启动时连接数据库的最大重试次数
MIGRATION_DB_MAX_RETRIES=30

# 两次重试之间的等待秒数
MIGRATION_DB_RETRY_INTERVAL_SECONDS=2


# ======================== 并发控制与后台任务 ========================

# 后台扫描间隔（秒）。控制 OpenClaw 轮询、forward outbox 重试的检查频率
BACKGROUND_SCAN_INTERVAL_SECONDS=300

# 聚合指标刷新间隔（秒）。建议 >= 30
METRICS_REFRESH_INTERVAL_SECONDS=60

# Forward outbox 记录被认领后，超过此秒数未完成则视为过期，允许其他 worker 重新认领
FORWARD_OUTBOX_STALE_SECONDS=300

# Worker 启动时的随机延迟（秒）。多实例同时重启时错峰抢槽位 / pending 消息
# 0 = 关闭
WORKER_STARTUP_JITTER_SECONDS=0


# ======================== Redis Stream MQ 配置 ========================
# Webhook 内部消息队列基于 Redis Stream

# Stream 名称
WEBHOOK_MQ_QUEUE=webhook:queue

# Consumer Group 名称。同一 group 内的 consumer 共享消费
WEBHOOK_MQ_CONSUMER_GROUP=webhook-processors

# 每次 XREADGROUP 拉取的最大消息数
WEBHOOK_MQ_CONSUMER_BATCH_SIZE=10

# XREADGROUP 阻塞等待超时（毫秒）
WEBHOOK_MQ_CONSUMER_TIMEOUT_MS=1000

# pending 消息空闲超过此毫秒数后，可被其他 worker 重新认领（XCLAIM）
WEBHOOK_MQ_PENDING_IDLE_TIMEOUT_MS=300000

# Stream 最大长度（使用 XTRIM approximate trim 保持）
WEBHOOK_MQ_STREAM_MAXLEN=100000


# ======================== AI 分析配置 ========================
# 调用 LLM 对告警进行智能分析

# 总开关。关闭后所有 webhook 不经过 AI，直接走规则匹配
ENABLE_AI_ANALYSIS=true

# LLM API 密钥
OPENAI_API_KEY=

# LLM API 基础地址。兼容 OpenAI 格式的服务商均可（OpenRouter / Azure / 自部署）
OPENAI_API_URL=https://openrouter.ai/api/v1

# 模型标识。按服务商支持的模型列表填写
OPENAI_MODEL=anthropic/claude-sonnet-4

# LLM 采样温度。越低输出越确定，越高越有创造力。告警分析建议 0.1-0.3
OPENAI_TEMPERATURE=0.2

# AI 系统提示词。定义分析角色和行为
AI_SYSTEM_PROMPT=你是一个专业的 DevOps 和系统运维专家...

# === 提示词模板 ===
# 用户提示词文件路径（相对于项目根目录）
AI_USER_PROMPT_FILE=prompts/webhook_analysis_detailed.txt
# 内联用户提示词（非空时覆盖文件）
AI_USER_PROMPT=

# 深度分析提示词文件路径
DEEP_ANALYSIS_PROMPT_FILE=prompts/deep_analysis.txt
# 内联深度分析提示词（非空时覆盖文件）
DEEP_ANALYSIS_PROMPT=

# === AI 降级 ===
# 开启后，当 AI 服务不可用（超时 / 限流 / 错误）时自动降级为规则匹配
# 关闭时 AI 失败会直接报错
ENABLE_AI_DEGRADATION=false

# === Payload 预处理 ===
# 发送给 AI 的 payload 最大字节数。超出截断以控制 token 消耗
AI_PAYLOAD_MAX_BYTES=32768

# 发送给 AI 前从 payload 中剥离的 key（逗号分隔），减少噪音和 token
AI_PAYLOAD_STRIP_KEYS=images,raw_trace,stacktrace,base64_data,screenshot,binary_data

# === 关键词规则 ===
# 触发 high 严重等级的关键词（逗号分隔，匹配 AI 分析结果）
RULE_HIGH_KEYWORDS=error,failure,critical,alert,错误,失败,故障

# 触发 warning 严重等级的关键词
RULE_WARN_KEYWORDS=warning,warn,警告

# 标识指标类告警的关键词（如 QPS、CPU、内存等）
RULE_METRIC_KEYWORDS=4xxqps,5xxqps,error,cpu,memory,disk

# 阈值放大系数。当告警值超过阈值的 N 倍时提升严重等级
RULE_THRESHOLD_MULTIPLIER=4.0

# === 缓存与成本 ===
# AI 分析结果缓存开关。开启后相同告警复用上次分析结果
CACHE_ENABLED=true

# 缓存 TTL（秒）。6 小时内的重复告警直接复用分析，不调 AI
ANALYSIS_CACHE_TTL=21600

# 每千 input token 的成本（USD），用于统计报表
AI_COST_PER_1K_INPUT_TOKENS=0.003

# 每千 output token 的成本（USD）
AI_COST_PER_1K_OUTPUT_TOKENS=0.015


# ======================== 降噪配置 ========================
# 识别和抑制由同一根因引发的关联告警风暴

# 降噪总开关
ENABLE_ALERT_NOISE_REDUCTION=true

# 时间窗口（分钟）。在此窗口内的告警参与关联分析
NOISE_REDUCTION_WINDOW_MINUTES=5

# 判定根因告警的最低置信度（0-1）。高于此分数的告警被标记为根因
ROOT_CAUSE_MIN_CONFIDENCE=0.65

# 两个告警被认为关联的最低置信度
NOISE_RELATED_MIN_CONFIDENCE=0.35

# === 降噪权重（五维评分，无需归一化）===
# 告警来源相似度权重
NOISE_SOURCE_WEIGHT=0.15

# 资源相似度权重（最重要维度，如同主机、同集群）
NOISE_RESOURCE_WEIGHT=0.45

# 语义相似度权重（AI 分析的事件描述相似度）
NOISE_SEMANTIC_WEIGHT=0.25

# 严重等级相似度权重
NOISE_SEVERITY_WEIGHT=0.10

# 时间接近度权重
NOISE_TIME_WEIGHT=0.20

# 严重等级降级阈值分数。派生告警的 severity 可能被降低
NOISE_SEVERITY_DOWNGRADE_SCORE=0.03

# 是否抑制派生告警的转发（只转发根因告警）
SUPPRESS_DERIVED_ALERT_FORWARD=true


# ======================== Retry / 去重 / 通知策略 ========================

# === 告警去重 ===
# 去重滑动窗口（秒）。相同指纹的告警在此时间内被归为同一条，不创建新记录
# 默认 4 小时。每次收到重复 webhook 时窗口从 last_seen_at 重新计时
DEDUP_WINDOW_SECONDS=14400

# AI 分析复用窗口（秒）。超过去重窗口后，在此时间内创建新告警但复用 AI 分析（不额外消耗 token）
# 默认 12 小时。两个窗口的关系：
#   0 - DEDUP_WINDOW          → REUSE（同一条告警，不调 AI）
#   DEDUP_WINDOW - 此值       → RECHAIN（新告警，复用 AI 分析）
#   超过此值                   → NEW（全新告警，全新 AI 分析）
ANALYSIS_REUSE_WINDOW_SECONDS=43200

# 是否转发被标记为重复的告警。通常 false，由转发规则的 match_duplicate 字段精细控制
FORWARD_DUPLICATE_ALERTS=false

# === 周期提醒 ===
# 同一告警持续存在时，是否定期重新发送通知
ENABLE_PERIODIC_REMINDER=true

# 周期提醒间隔（小时）。上次通知超过此时间后会再次通知
REMINDER_INTERVAL_HOURS=6

# 重复告警的通知冷却时间（秒）。同一告警两次通知之间的最短间隔
NOTIFICATION_COOLDOWN_SECONDS=60

# === 告警风暴背压 ===
# 是否启用基于 Redis 的分布式处理锁
PROCESSING_LOCK_DISTRIBUTED_ENABLED=true

# 分布式锁 TTL（秒）。处理时间超过此值后锁自动释放
PROCESSING_LOCK_TTL_SECONDS=180

# 等待获取锁的最大超时（秒）
PROCESSING_LOCK_WAIT_TIMEOUT_SECONDS=15

# 等待锁时的轮询间隔（毫秒）
PROCESSING_LOCK_POLL_INTERVAL_MS=100

# 背压快速失败阈值。同一 alert_hash 在窗口内超过此数量时直接丢弃新请求
PROCESSING_LOCK_FAILFAST_THRESHOLD=20

# 快速失败计数的时间窗口（秒）
PROCESSING_LOCK_FAILFAST_WINDOW_SECONDS=10

# Redis 不可用时背压检查是否放行（fail-open）
INGRESS_BACKPRESSURE_FAIL_OPEN_ON_REDIS_ERROR=false

# === Webhook 处理重试 ===
# Webhook 处理失败（非业务错误）时的最大重试次数
WEBHOOK_RETRY_MAX_RETRIES=5

# 首次重试等待秒数
WEBHOOK_RETRY_INITIAL_DELAY=30

# 重试等待上限（秒）
WEBHOOK_RETRY_MAX_DELAY=900

# 指数退避倍数。delay = min(initial * multiplier^n, max_delay)
WEBHOOK_RETRY_BACKOFF_MULTIPLIER=2.0

# === Forward Outbox 重试 ===
# 转发投递失败后的最大重试次数
FORWARD_RETRY_MAX_RETRIES=3

# 首次转发重试等待秒数
FORWARD_RETRY_INITIAL_DELAY=60

# 转发重试等待上限（秒）
FORWARD_RETRY_MAX_DELAY=3600

# 转发重试指数退避倍数
FORWARD_RETRY_BACKOFF_MULTIPLIER=2.0

# 转发意图最大存活时间（秒）。超过后标记 expired，不再发送旧告警
# 0 = 关闭过期保护
FORWARD_MAX_DELIVERY_AGE_SECONDS=1800


# ======================== Forwarding 配置 ========================
# 告警转发到外部系统（飞书、自定义 webhook 等）的行为

# 单次转发 HTTP 请求超时（秒）
FORWARD_TIMEOUT=10


# ======================== 飞书集成 ========================

# 深度分析结果发送到飞书的 webhook URL
DEEP_ANALYSIS_FEISHU_WEBHOOK=

# 飞书 webhook HTTP 请求超时（秒）
FEISHU_WEBHOOK_TIMEOUT=10

# AI 服务异常时的飞书通知冷却时间（秒）。避免频繁轰炸
AI_ERROR_NOTIFICATION_COOLDOWN_SECONDS=3600


# ======================== OpenClaw 配置 ========================
# OpenClaw 深度分析引擎集成

# OpenClaw 总开关
OPENCLAW_ENABLED=false

# 深度分析平台选择：openclaw
DEEP_ANALYSIS_PLATFORM=openclaw

# OpenClaw Gateway API 地址
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18900

# Gateway 认证 token
OPENCLAW_GATEWAY_TOKEN=

# Hooks 回调验证 token
OPENCLAW_HOOKS_TOKEN=

# OpenClaw HTTP API 地址
OPENCLAW_HTTP_API_URL=http://127.0.0.1:8085

# 单次深度分析任务的整体超时（秒）。默认 15 分钟
OPENCLAW_TIMEOUT_SECONDS=900

# === 轮询策略 ===
# 分析结果连续稳定（内容不变）多少次后视为完成
OPENCLAW_STABILITY_REQUIRED_HITS=2

# 提交分析后首次轮询的延迟（秒）
OPENCLAW_POLL_INITIAL_DELAY_SECONDS=10

# 轮询间隔上限（秒）。退避不会超过此值
OPENCLAW_POLL_MAX_DELAY_SECONDS=120

# 轮询指数退避倍数
OPENCLAW_POLL_BACKOFF_MULTIPLIER=2.0

# 连续错误多少次后熔断
OPENCLAW_MAX_CONSECUTIVE_ERRORS=8

# OpenClaw 不可用时是否降级（跳过深度分析继续处理）
OPENCLAW_ENABLE_DEGRADATION=false

# === 超时 ===
# HTTP 连接超时（秒）
OPENCLAW_CONNECT_TIMEOUT=20

# 设备认证 nonce 生成超时（秒）
OPENCLAW_NONCE_TIMEOUT=5

# 单次轮询 HTTP 请求超时（秒）
OPENCLAW_POLL_TIMEOUT=180

# === Device Auth ===
# 设备认证 ID
OPENCLAW_DEVICE_ID=

# 设备认证 PEM 格式私钥
OPENCLAW_DEVICE_PRIVATE_KEY_PEM=

# 预配置的设备 token（替代私钥认证）
OPENCLAW_DEVICE_TOKEN=


# ======================== Circuit Breaker 配置 ========================
# 熔断器：连续失败后自动停止对外部服务的调用，定期试探恢复

# 飞书 webhook 连续失败多少次后熔断
CIRCUIT_BREAKER_FEISHU_THRESHOLD=5

# 飞书熔断后等待多少秒进入半开状态（允许一次试探请求）
CIRCUIT_BREAKER_FEISHU_TIMEOUT=30.0

# OpenClaw 连续失败多少次后熔断
CIRCUIT_BREAKER_OPENCLAW_THRESHOLD=5

# OpenClaw 熔断恢复等待秒数
CIRCUIT_BREAKER_OPENCLAW_TIMEOUT=30.0

# 转发目标连续失败多少次后熔断
CIRCUIT_BREAKER_FORWARD_THRESHOLD=5

# 转发目标熔断恢复等待秒数
CIRCUIT_BREAKER_FORWARD_TIMEOUT=30.0


# ======================== 数据维护 / 保留策略 ========================
# 自动清理过期告警数据

# 定期清理总开关
ENABLE_DATA_CLEANUP=true

# 默认数据保留天数
DATA_RETENTION_DAYS_DEFAULT=30

# 按告警重要等级的保留天数覆盖（JSON 对象）
# high=90天, medium=30天, low=7天, unknown=3天
RETENTION_POLICIES={"high":90,"medium":30,"low":7,"unknown":3}

# 按告警来源的保留天数覆盖（JSON 对象）
SOURCE_RETENTION_POLICIES={"prometheus":30,"grafana":30,"datadog":30}

# 清理分类关键词（JSON 对象）。匹配到这些关键词的告警可能被加速清理
CLEANUP_KEYWORDS={"summary":["一般事件:","测试告警"],"parsed_data":["一般事件"]}

# 每天执行清理任务的时间（小时，0-23）
MAINTENANCE_HOUR=3


# ======================== OpenTelemetry 配置 ========================
# 分布式追踪、指标、日志的统一采集

# OTel 总开关。关闭后所有 trace/metric/log 不再上报
OTEL_ENABLED=false

# === 资源标识 ===
# 服务名称，在 trace/metric/log 中标识来源服务
OTEL_SERVICE_NAME=webhookwise

# 服务命名空间，用于区分同名服务族
OTEL_SERVICE_NAMESPACE=webhookwise

# 服务版本。优先级：OTEL_SERVICE_VERSION > SERVICE_VERSION > APP_VERSION
OTEL_SERVICE_VERSION=unknown
SERVICE_VERSION=
APP_VERSION=

# 部署环境标识。优先级：OTEL_DEPLOYMENT_ENVIRONMENT > APP_ENV
OTEL_DEPLOYMENT_ENVIRONMENT=production

# 服务实例 ID。多实例部署时用于区分。优先级：OTEL_SERVICE_INSTANCE_ID > SERVICE_INSTANCE_ID
OTEL_SERVICE_INSTANCE_ID=
SERVICE_INSTANCE_ID=

# OTel semantic convention / schema version。升级语义约定时显式改这里
OTEL_SEMCONV_VERSION=1.41.0
OTEL_SCHEMA_URL=https://opentelemetry.io/schemas/1.41.0

# === Trace 控制 ===
# 是否将 trace 输出到控制台（调试用）
OTEL_CONSOLE_EXPORTER=false

# 是否对 healthcheck 端点（/live, /ready）生成 trace
OTEL_INCLUDE_HEALTHCHECKS=false

# 不生成 trace 的 URL 路径（逗号分隔）
OTEL_EXCLUDED_URLS=/live,/ready,/static

# === OTLP Exporter ===
# 统一 endpoint。设置后 traces/metrics/logs 都发往此处
OTEL_EXPORTER_OTLP_ENDPOINT=

# 按信号分别设置 endpoint（优先级高于统一 endpoint）
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=

# 导出协议：grpc 或 http/protobuf
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# OTLP 请求头（逗号分隔的 key=value），用于认证
OTEL_EXPORTER_OTLP_HEADERS=

# OTLP 请求超时（秒）
OTEL_EXPORTER_OTLP_TIMEOUT=10

# 是否使用不加密的 gRPC 连接（仅开发/内网使用）
OTEL_EXPORTER_OTLP_INSECURE=false

# === 日志导出 ===
# 是否将应用日志通过 OTLP 导出
OTEL_LOGS_ENABLED=true

# === 采样 ===
# HTTP 语义约定稳定性 opt-in
OTEL_SEMCONV_STABILITY_OPT_IN=http

# Trace 采样策略。生产建议 parentbased_traceidratio；开发可设 always_on
OTEL_TRACES_SAMPLER=parentbased_traceidratio

# 采样比例（0-1）。0.1 = 10% 的请求被采样
OTEL_TRACES_SAMPLER_ARG=0.1

# === 基数保护 ===
# Gauge 指标的最大时间序列数，防止因高基数 attributes 导致内存膨胀
WEBHOOKWISE_GAUGE_SERIES_LIMIT=512

# MetricReader 导出周期和超时（毫秒）
OTEL_METRIC_EXPORT_INTERVAL=60000
OTEL_METRIC_EXPORT_TIMEOUT=30000

# Histogram exemplar 过滤策略。trace_based 让带 trace 的样本可从 Grafana 指标点跳 Tempo
OTEL_METRICS_EXEMPLAR_FILTER=trace_based

# webhook.source label 的最大去重数量，超出后归入 "other"
WEBHOOKWISE_SOURCE_LABEL_LIMIT=128


# ======================== Pyroscope / Profiles 配置 ========================
# 持续性能分析（CPU / 内存火焰图）

# Profiling 总开关。两个任一为 true 即启用
PYROSCOPE_ENABLED=false
OTEL_PROFILES_ENABLED=false

# 是否启用 span-to-profile 关联（在 trace 中可跳转到对应时刻的 profile）
PYROSCOPE_SPAN_PROFILES_ENABLED=true

# 应用名称。空时使用 OTEL_SERVICE_NAME
PYROSCOPE_APPLICATION_NAME=

# Pyroscope 服务地址。PYROSCOPE_SERVER_ADDRESS 优先，PYROSCOPE_URL 为备选
PYROSCOPE_SERVER_ADDRESS=
PYROSCOPE_URL=

# 采样率（每秒采集次数）
PYROSCOPE_SAMPLE_RATE=100

# 仅采集 CPU 上运行的时间
PYROSCOPE_ONCPU=true

# 仅采集持有 GIL 的线程（Python 特有，减少噪音）
PYROSCOPE_GIL_ONLY=true

# 是否开启 Pyroscope 客户端库日志
PYROSCOPE_ENABLE_LOGGING=false

# 自定义标签（逗号分隔的 key=value）
PYROSCOPE_TAGS=

# Bearer Token 认证
PYROSCOPE_AUTH_TOKEN=

# Basic Auth 认证
PYROSCOPE_BASIC_AUTH_USERNAME=
PYROSCOPE_BASIC_AUTH_PASSWORD=

# 多租户 ID
PYROSCOPE_TENANT_ID=


# ======================== Observability Query CLI / MCP 配置 ========================
# 用于 scripts/observability/ 下的诊断脚本和 MCP 服务

# 查询模式：direct=直接访问各服务，grafana-proxy=通过 Grafana API 代理查询
WEBHOOKWISE_QUERY_MODE=direct

# 各服务地址
WEBHOOKWISE_PROMETHEUS_URL=http://localhost:9090
WEBHOOKWISE_LOKI_URL=http://localhost:3100
WEBHOOKWISE_TEMPO_URL=http://localhost:3200
WEBHOOKWISE_GRAFANA_URL=http://localhost:3000
WEBHOOKWISE_PYROSCOPE_URL=http://localhost:4040
WEBHOOKWISE_ALLOY_URL=http://localhost:12345
WEBHOOKWISE_API_URL=http://localhost:8000

# Grafana 认证（Basic Auth 或 Token，Token 优先）
WEBHOOKWISE_GRAFANA_USER=admin
WEBHOOKWISE_GRAFANA_PASSWORD=admin
WEBHOOKWISE_GRAFANA_TOKEN=

# Grafana 中各数据源的 UID
WEBHOOKWISE_PROMETHEUS_DATASOURCE_UID=prometheus
WEBHOOKWISE_LOKI_DATASOURCE_UID=loki
WEBHOOKWISE_TEMPO_DATASOURCE_UID=tempo
WEBHOOKWISE_PYROSCOPE_DATASOURCE_UID=pyroscope

# HTTP 请求 User-Agent
WEBHOOKWISE_HTTP_USER_AGENT=WebhookWise-Observability/0.1

# Smoke 测试的运行 ID（留空自动生成）
WEBHOOKWISE_SMOKE_RUN_ID=

# Smoke 测试发送 webhook 后等待多少秒再检查指标
WEBHOOKWISE_SMOKE_WAIT_SECONDS=8


# ======================== Local Observability Stack ========================
# Docker Compose observability stack 的镜像版本（仅影响 docker-compose.observability.yml）

ALERTMANAGER_IMAGE=prom/alertmanager:v0.27.0
ALLOY_IMAGE=grafana/alloy:v1.5.1
BEYLA_IMAGE=grafana/beyla:3.14.0
K6_IMAGE=grafana/k6:0.55.0
LOKI_IMAGE=grafana/loki:3.2.1
PROMETHEUS_IMAGE=prom/prometheus:v2.55.1
TEMPO_IMAGE=grafana/tempo:2.6.1
PYROSCOPE_IMAGE=grafana/pyroscope:1.9.0
GRAFANA_IMAGE=grafana/grafana:11.3.0

# Grafana 管理员账号
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Faro 接收器端口（前端 RUM 数据）
FARO_RECEIVER_PORT=12347

# K6 压测脚本的目标地址
K6_BASE_URL=http://webhook-service:8000
K6_RUN_ID=
