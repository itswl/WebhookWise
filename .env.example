# 服务器配置
FLASK_APP=app.py
FLASK_ENV=development
HOST=0.0.0.0
PORT=5000

# 数据库配置
DATABASE_URL=postgresql://username:password@localhost:5432/webhooks
# 数据库连接池配置
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30

# Webhook 安全配置
WEBHOOK_SECRET=your-secret-key-here

# 日志配置
LOG_LEVEL=INFO

# 数据存储配置
# 是否启用文件备份（除数据库外额外保存到文件）
ENABLE_FILE_BACKUP=false

# AI 分析和转发配置
ENABLE_AI_ANALYSIS=true
ENABLE_FORWARD=true
FORWARD_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_KEY

# OpenAI API 配置
OPENAI_API_KEY=sk-or-v1-xxxxx
OPENAI_API_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=anthropic/claude-sonnet-4

# AI 提示词配置
# System Prompt - AI 的角色设定
AI_SYSTEM_PROMPT=你是一个专业的 DevOps 和系统运维专家，擅长分析 webhook 事件并提供准确的运维建议。你的职责是：1. 快速识别事件类型和严重程度 2. 提供清晰的问题摘要 3. 给出可执行的处理建议 4. 识别潜在风险和影响范围 5. 建议监控和预防措施

# User Prompt - 用户输入模板配置（二选一）
# 方式1：从文件加载（推荐）- 相对路径或绝对路径
# 可选模板：
#   - prompts/webhook_analysis.txt (默认通用版)
#   - prompts/webhook_analysis_simple.txt (简化版)
#   - prompts/webhook_analysis_detailed.txt (详细版，推荐生产环境)
AI_USER_PROMPT_FILE=prompts/webhook_analysis_detailed.txt
# 方式2：直接设置内容（优先级更高，设置后会忽略文件）
# AI_USER_PROMPT=请分析以下 webhook 事件...

# ============================================================
# 重复告警去重配置
# ============================================================

# 去重时间窗口（小时）
# 在此时间内相同告警视为重复，默认 24 小时
# 取值范围：1-168（7天）
DUPLICATE_ALERT_TIME_WINDOW=24

# 【窗口内】重复告警是否转发
# true: 窗口内的重复告警也会转发（不推荐，会导致通知轰炸）
# false: 窗口内的重复告警不转发（推荐）
FORWARD_DUPLICATE_ALERTS=false

# ============================================================
# 超时间窗口后的行为配置（新增）
# ============================================================
# 说明：当告警超过时间窗口后再次出现，如何处理？

# 是否重新调用 AI 分析
# true: 重新分析，确保结果最新（会产生 AI API 费用）
# false: 复用历史分析结果（节省 AI API 费用，推荐）
# 场景：
#   - 告警内容可能变化 → 设置 true
#   - 告警内容固定 → 设置 false 节省费用
REANALYZE_AFTER_TIME_WINDOW=true

# 是否推送转发（高风险告警）
# true: 定期提醒持续问题（例如每24小时提醒一次）
# false: 不推送，避免重复通知
# 场景：
#   - 需要定期关注持续问题 → 设置 true
#   - 避免通知疲劳 → 设置 false
FORWARD_AFTER_TIME_WINDOW=true

# ============================================================
# 配置组合建议
# ============================================================
# 场景1 - 成本敏感（推荐生产环境）：
#   REANALYZE_AFTER_TIME_WINDOW=false  # 节省 AI 费用
#   FORWARD_AFTER_TIME_WINDOW=true     # 但仍然提醒
#
# 场景2 - 准确性优先：
#   REANALYZE_AFTER_TIME_WINDOW=true   # 最新分析
#   FORWARD_AFTER_TIME_WINDOW=true     # 定期提醒
#
# 场景3 - 静默模式（已知持续问题）：
#   REANALYZE_AFTER_TIME_WINDOW=false  # 节省费用
#   FORWARD_AFTER_TIME_WINDOW=false    # 避免通知
#
# 场景4 - 仅记录不通知：
#   REANALYZE_AFTER_TIME_WINDOW=true   # 保持分析最新
#   FORWARD_AFTER_TIME_WINDOW=false    # 不推送
# ============================================================

# ============================================================
# 周期性提醒配置（新增）
# ============================================================
# 说明：即使在窗口内，长时间持续的告警也需要周期性提醒
#       防止"告警持续30小时但只通知1次"的问题

# 是否启用周期性提醒
# true: 启用周期性提醒（推荐）
# false: 禁用，窗口内重复告警不会再次通知
# 场景：
#   - 防止长期问题被忽略 → 设置 true（推荐）
#   - 避免通知频繁 → 设置 false
ENABLE_PERIODIC_REMINDER=true

# 周期性提醒间隔（小时）
# 在窗口内，如果告警持续重复，每隔此时间提醒一次
# 推荐值：6（每6小时提醒一次）
# 取值范围：1-24
# 场景：
#   - 关键告警 → 设置 1-3（频繁提醒）
#   - 一般告警 → 设置 6-12（适中）
#   - 低优先级 → 设置 24（每天提醒一次）
REMINDER_INTERVAL_HOURS=6

# ============================================================
# 周期性提醒配置组合建议
# ============================================================
# 场景1 - 关键系统（推荐）：
#   ENABLE_PERIODIC_REMINDER=true
#   REMINDER_INTERVAL_HOURS=6     # 每6小时提醒
#
# 场景2 - 频繁告警系统：
#   ENABLE_PERIODIC_REMINDER=true
#   REMINDER_INTERVAL_HOURS=12    # 每12小时提醒，避免疲劳
#
# 场景3 - 低优先级系统：
#   ENABLE_PERIODIC_REMINDER=true
#   REMINDER_INTERVAL_HOURS=24    # 每天提醒一次
#
# 场景4 - 仅首次通知：
#   ENABLE_PERIODIC_REMINDER=false # 禁用周期性提醒
# ============================================================
