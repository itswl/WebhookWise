# Webhook AI 分析服务环境配置文件
# -------------------------------------------------------------
# 注意: 布尔类型使用 true/false 即可。数值类型直接写数字。
#       留空的变量表示非必须，或者是启用特定功能才需要填写的 Token。
# -------------------------------------------------------------


# ============================================================
# 服务器与网络配置
# ============================================================
PORT=8000
HOST=0.0.0.0
DEBUG=false
WEBHOOK_SECRET=
LOG_LEVEL=INFO
LOG_FILE=logs/webhook.log

# ============================================================
# 数据存储与基础组件配置
# ============================================================
DATA_DIR=webhooks_data
ENABLE_FILE_BACKUP=false
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/webhooks
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30

# ============================================================
# 通用 AI 分析与转发总控
# ============================================================
ENABLE_AI_ANALYSIS=true
ENABLE_AI_DEGRADATION=false
FORWARD_URL=
ENABLE_FORWARD=true

# ============================================================
# OpenAI API 模型配置
# ============================================================
OPENAI_API_KEY=
OPENAI_API_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=anthropic/claude-sonnet-4
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=1800
OPENAI_TRUNCATION_RETRY_MAX_TOKENS=2600

# ============================================================
# AI 提示词配置
# ============================================================
AI_SYSTEM_PROMPT='你是一个专业的 DevOps 和系统运维专家...'
AI_USER_PROMPT_FILE=prompts/webhook_analysis_detailed.txt
AI_USER_PROMPT=

# ============================================================
# 告警去重与时间窗口策略
# ============================================================
DUPLICATE_ALERT_TIME_WINDOW=24
FORWARD_DUPLICATE_ALERTS=false
REANALYZE_AFTER_TIME_WINDOW=true
FORWARD_AFTER_TIME_WINDOW=true
ENABLE_PERIODIC_REMINDER=true
REMINDER_INTERVAL_HOURS=6

# ============================================================
# 并发与超时控制
# ============================================================
PROCESSING_LOCK_TTL_SECONDS=120
PROCESSING_LOCK_WAIT_SECONDS=3
RECENT_BEYOND_WINDOW_REUSE_SECONDS=30
NOTIFICATION_COOLDOWN_SECONDS=60
SAVE_MAX_RETRIES=3
SAVE_RETRY_DELAY_SECONDS=0.1

# ============================================================
# 智能降噪与根因分析 (AIOps)
# ============================================================
ENABLE_ALERT_NOISE_REDUCTION=true
NOISE_REDUCTION_WINDOW_MINUTES=5
ROOT_CAUSE_MIN_CONFIDENCE=0.65
SUPPRESS_DERIVED_ALERT_FORWARD=true
CACHE_ENABLED=true
ANALYSIS_CACHE_TTL=21600
SMART_ROUTING_ENABLED=true
AI_COST_PER_1K_INPUT_TOKENS=0.003
AI_COST_PER_1K_OUTPUT_TOKENS=0.015

# ============================================================
# ChatOps 与飞书相关集成
# ============================================================
CHATOPS_ENABLED=false
FEISHU_BOT_APP_ID=
FEISHU_BOT_APP_SECRET=
DEEP_ANALYSIS_FEISHU_WEBHOOK=

# ============================================================
# OpenClaw 深度分析集成
# ============================================================
OPENCLAW_ENABLED=false
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18900
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_HOOKS_TOKEN=
OPENCLAW_HTTP_API_URL=http://127.0.0.1:8085
OPENCLAW_TIMEOUT_SECONDS=300
DEEP_ANALYSIS_ENGINE=local

# ============================================================
# OpenClaw 高级轮询策略
# ============================================================
OPENCLAW_STABILITY_REQUIRED_HITS=2
OPENCLAW_MIN_WAIT_SECONDS=30
OPENCLAW_MAX_CONSECUTIVE_ERRORS=5
OPENCLAW_CONNECT_TIMEOUT=10
OPENCLAW_HANDSHAKE_TIMEOUT=5
OPENCLAW_RECV_TIMEOUT=1.0
OPENCLAW_NONCE_TIMEOUT=2.0
OPENCLAW_POLL_TIMEOUT=90

# ============================================================
# OpenClaw 设备级安全认证 (Device Auth)
# ============================================================
OPENCLAW_DEVICE_ID=
OPENCLAW_DEVICE_PRIVATE_KEY_PEM=
OPENCLAW_DEVICE_TOKEN=

# ============================================================
# 熔断器安全策略 (Circuit Breakers)
# ============================================================
CIRCUIT_BREAKER_FEISHU_THRESHOLD=5
CIRCUIT_BREAKER_FEISHU_TIMEOUT=30.0
CIRCUIT_BREAKER_OPENCLAW_THRESHOLD=5
CIRCUIT_BREAKER_OPENCLAW_TIMEOUT=30.0
CIRCUIT_BREAKER_FORWARD_THRESHOLD=5
CIRCUIT_BREAKER_FORWARD_TIMEOUT=30.0
AI_API_TIMEOUT=10
FEISHU_WEBHOOK_TIMEOUT=10
FORWARD_TIMEOUT=10

# ============================================================
# 系统内部杂项
# ============================================================
JSON_SORT_KEYS=false
JSONIFY_PRETTYPRINT_REGULAR=true
