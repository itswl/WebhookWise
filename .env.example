# ============================================================
# 静态基础设施配置（仅启动时读取，修改后需重启）
# 业务策略可选择迁移到数据库 system_configs 表热更新
# 连接/密钥类配置默认仍走环境变量/ConfigMap + 滚动重启
# ============================================================

# ====== Server 配置 ======
HOST=0.0.0.0
PORT=8000
# 环境: development / production
APP_ENV=production
# Prometheus metrics 端口（0=禁用）
METRICS_PORT=0
# 独立 worker 容器的后台任务指标端口，Compose 默认仅在容器网络内 expose。
WORKER_METRICS_PORT=9001
# Prometheus 多进程指标目录（Gunicorn 多 Worker 时必需）
# PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc

# 运行模式: api=仅HTTP服务 | worker=仅TaskIQ消费进程 | scheduler=仅定时任务投递进程 | all=supervisor 同容器启动三者
# 默认 Compose 使用独立 api/worker/scheduler 服务；如需 all-in-one，使用 docker-compose.supervisor.yml override。
RUN_MODE=api
# 是否启用 DB/Redis 运行时配置；生产默认建议 false，改配置后滚动重启。
ENABLE_RUNTIME_CONFIG=false
# 是否允许连接/密钥类配置热更新（OPENAI_API_KEY/OPENCLAW_GATEWAY_TOKEN 等）；默认 false，避免多进程配置不一致。
ALLOW_RUNTIME_CONNECTION_CONFIG=false
# RUN_MODE=all 时 API Gunicorn worker 数
API_WORKERS=4
# Worker 节点唯一标识（默认取主机名+PID）
# 使用 docker compose --scale worker=N 时不要手动设置固定 WORKER_ID，否则多个 worker 会共用同一个 Redis consumer 名称。
# WORKER_ID=

# ====== Security 配置 ======
WEBHOOK_SECRET=please-change-webhook-secret
API_KEY=please-change-api-key
# Admin 写操作（修改配置、重放事件、DDL 迁移）单独的 API Key
# 为空时退回到普通 API_KEY 行为（向后兼容）
ADMIN_WRITE_KEY=please-change-admin-write-key
ALLOW_UNAUTHENTICATED_ADMIN=false
ALLOW_UNAUTHENTICATED_WEBHOOK=false
MAX_WEBHOOK_BODY_BYTES=1048576
WEBHOOK_RATE_LIMIT_PER_MINUTE=600
# 每 IP 每 10 秒突发上限（0=不限），防止瞬间洪峰
WEBHOOK_RATE_LIMIT_BURST=200
# 全局每分钟总上限（0=不限），保护后端处理能力
WEBHOOK_RATE_LIMIT_GLOBAL_PER_MINUTE=0
# 生产环境默认要求鉴权；如确需公开接收，显式设置 ALLOW_UNAUTHENTICATED_WEBHOOK=true
REQUIRE_WEBHOOK_AUTH=true
# 只有请求来自可信代理时才采信 X-Forwarded-For / X-Real-IP
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
# 默认禁止转发到 localhost/内网/保留地址；本地联调确需内网目标时显式开启
ALLOW_PRIVATE_FORWARD_URLS=false
# 可选：限制转发目标域名，支持 example.com、.example.com、*.example.com，空=允许公网域名
FORWARD_TARGET_ALLOWLIST=

# ====== Redis 配置 ======
REDIS_URL=redis://localhost:6379/0

# ====== DB 配置 ======
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/webhooks
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30
# SQL 语句超时(ms)，推荐范围 5000-30000，不建议低于 5000
# 超时后 PostgreSQL 自动取消查询，pipeline 会捕获该异常并安全重试
DB_STATEMENT_TIMEOUT_MS=30000
# 关闭同步提交可提升写入 3-5x，但断电时可能丢失最近 1-2 秒数据
# 对 Webhook 场景可接受（有 Redis MQ + RecoveryPoller 兜底）
DB_SYNC_COMMIT=off

# 日志与数据存储
LOG_FILE=logs/webhook.log
DATA_DIR=webhooks_data

# ====== 并发控制与超时 ======
# 旧版 RecoveryPoller 间隔配置；保留兼容，常规兜底扫描使用 RECOVERY_SCAN_INTERVAL_SECONDS。
RECOVERY_POLLER_INTERVAL_SECONDS=60
# recovery-only 兜底扫描间隔秒数（DB scan 低频兜底，正常路径走 Redis/TaskIQ 调度）
RECOVERY_SCAN_INTERVAL_SECONDS=300
# Metrics 刷新间隔秒数（建议 ≥30）
METRICS_REFRESH_INTERVAL_SECONDS=60
# 事件僵尸判定阈值秒数
RECOVERY_POLLER_STUCK_THRESHOLD_SECONDS=300
# 优雅停机等待超时秒数
GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=30
# 单个转发请求超时秒数
FORWARD_REQUEST_TIMEOUT_SECONDS=10
# 超过该字节数的 payload 解码/清洗将使用 asyncio.to_thread() 执行，避免阻塞事件循环
PAYLOAD_OFFLOAD_THRESHOLD_BYTES=524288
# 所有 worker 全局 webhook 处理并发上限（Redis 分布式令牌；0=不限；通常不建议关闭）
MAX_CONCURRENT_WEBHOOK_TASKS=30
# 全局并发令牌租约秒数，长任务会自动续期
WEBHOOK_TASK_SLOT_LEASE_SECONDS=1800

# ====== Redis Stream MQ 配置 ======
# Webhook 消息队列 Stream 名称
WEBHOOK_MQ_QUEUE=webhook:queue
# Consumer Group 名称
WEBHOOK_MQ_CONSUMER_GROUP=webhook-processors
# 每次拉取的最大消息数
WEBHOOK_MQ_CONSUMER_BATCH_SIZE=10
# XREADGROUP 阻塞超时毫秒数
WEBHOOK_MQ_CONSUMER_TIMEOUT_MS=1000
# Redis Stream pending 消息被 worker 重新认领的空闲阈值毫秒数
WEBHOOK_MQ_PENDING_IDLE_TIMEOUT_MS=300000
# Stream 最大长度（approximate trim）
WEBHOOK_MQ_STREAM_MAXLEN=100000
# ====== AI 配置 ======
OPENAI_TEMPERATURE=0.2

# AI 提示词文件
AI_USER_PROMPT_FILE=prompts/webhook_analysis_detailed.txt
AI_USER_PROMPT=

# ====== Retry 配置 ======
# 周期提醒
ENABLE_PERIODIC_REMINDER=true
REMINDER_INTERVAL_HOURS=6

# 告警风暴背压
PROCESSING_LOCK_DISTRIBUTED_ENABLED=true
PROCESSING_LOCK_TTL_SECONDS=180
PROCESSING_LOCK_WAIT_TIMEOUT_SECONDS=15
PROCESSING_LOCK_POLL_INTERVAL_MS=100
PROCESSING_LOCK_FAILFAST_THRESHOLD=20
PROCESSING_LOCK_FAILFAST_WINDOW_SECONDS=10
RECENT_BEYOND_WINDOW_REUSE_SECONDS=30
NOTIFICATION_COOLDOWN_SECONDS=60
WEBHOOK_RETRY_MAX_RETRIES=5
WEBHOOK_RETRY_INITIAL_DELAY=30
WEBHOOK_RETRY_MAX_DELAY=900
WEBHOOK_RETRY_BACKOFF_MULTIPLIER=2.0

# 转发失败重试补偿（TaskIQ 动态延迟任务，DB 保存审计状态）
ENABLE_FORWARD_RETRY=true
FORWARD_RETRY_MAX_RETRIES=3
FORWARD_RETRY_INITIAL_DELAY=60
FORWARD_RETRY_MAX_DELAY=3600
FORWARD_RETRY_BACKOFF_MULTIPLIER=2.0

# AIOps 缓存策略
CACHE_ENABLED=true
ANALYSIS_CACHE_TTL=21600
AI_COST_PER_1K_INPUT_TOKENS=0.003
AI_COST_PER_1K_OUTPUT_TOKENS=0.015

# ====== 飞书集成 ======
DEEP_ANALYSIS_FEISHU_WEBHOOK=

# ====== OpenClaw 配置 ======
OPENCLAW_ENABLED=false
DEEP_ANALYSIS_PLATFORM=openclaw
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18900
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_HOOKS_TOKEN=
OPENCLAW_HTTP_API_URL=http://127.0.0.1:8085
OPENCLAW_TIMEOUT_SECONDS=900

# OpenClaw 高级轮询与超时
OPENCLAW_STABILITY_REQUIRED_HITS=2
OPENCLAW_POLL_INITIAL_DELAY_SECONDS=10
OPENCLAW_POLL_MAX_DELAY_SECONDS=120
OPENCLAW_POLL_BACKOFF_MULTIPLIER=2.0
OPENCLAW_MAX_CONSECUTIVE_ERRORS=8
OPENCLAW_ENABLE_DEGRADATION=false
OPENCLAW_CONNECT_TIMEOUT=20
OPENCLAW_HANDSHAKE_TIMEOUT=10
OPENCLAW_NONCE_TIMEOUT=5
OPENCLAW_POLL_TIMEOUT=180

# OpenClaw Device Auth
OPENCLAW_DEVICE_ID=
OPENCLAW_DEVICE_PRIVATE_KEY_PEM=
OPENCLAW_DEVICE_TOKEN=

# ====== CircuitBreaker 配置 ======
CIRCUIT_BREAKER_FEISHU_THRESHOLD=5
CIRCUIT_BREAKER_FEISHU_TIMEOUT=30.0
CIRCUIT_BREAKER_OPENCLAW_THRESHOLD=5
CIRCUIT_BREAKER_OPENCLAW_TIMEOUT=30.0
CIRCUIT_BREAKER_FORWARD_THRESHOLD=5
CIRCUIT_BREAKER_FORWARD_TIMEOUT=30.0

# ====== OpenTelemetry (Tracing) ======
OTEL_ENABLED=false
OTEL_SERVICE_NAME=webhookwise
OTEL_CONSOLE_EXPORTER=false
OTEL_EXCLUDED_URLS=/metrics,/static
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_TIMEOUT=10
OTEL_EXPORTER_OTLP_INSECURE=false

# HTTP 请求超时（秒）
FEISHU_WEBHOOK_TIMEOUT=10
FORWARD_TIMEOUT=10

# AI 降级开关
ENABLE_AI_DEGRADATION=false

# 以下业务策略配置可迁移到数据库 system_configs 表，启用 ENABLE_RUNTIME_CONFIG 后可通过 Web 界面修改：
# ═════════════════════════════════════════════════════════════
# 以下为业务策略配置的默认值
# 运行时由数据库 system_configs 表管理，通过 Web 管理界面修改
# .env 中的值可作为首次部署的初始值；生产建议对连接/密钥类配置继续使用环境变量/ConfigMap
# 如需排查某个 key 当前来自 env 还是 DB，可调用 /api/config/sources 查看来源与更新时间
# ═════════════════════════════════════════════════════════════
# ENABLE_AI_ANALYSIS, ENABLE_FORWARD, FORWARD_URL, AI_SYSTEM_PROMPT, LOG_LEVEL,
# DUPLICATE_ALERT_TIME_WINDOW, FORWARD_DUPLICATE_ALERTS,
# REANALYZE_AFTER_TIME_WINDOW, FORWARD_AFTER_TIME_WINDOW,
# ENABLE_PERIODIC_REMINDER, REMINDER_INTERVAL_HOURS, NOTIFICATION_COOLDOWN_SECONDS,
# ENABLE_ALERT_NOISE_REDUCTION, NOISE_REDUCTION_WINDOW_MINUTES,
# ROOT_CAUSE_MIN_CONFIDENCE, SUPPRESS_DERIVED_ALERT_FORWARD,
# RULE_HIGH_KEYWORDS, RULE_WARN_KEYWORDS, RULE_METRIC_KEYWORDS,
# RULE_THRESHOLD_MULTIPLIER, AI_PAYLOAD_MAX_BYTES, AI_PAYLOAD_STRIP_KEYS
# OPENAI_API_KEY, OPENAI_API_URL, OPENCLAW_GATEWAY_URL,
# OPENCLAW_GATEWAY_TOKEN, OPENCLAW_HOOKS_TOKEN, OPENCLAW_HTTP_API_URL 默认需重启生效；
# 如明确接受多进程短暂不一致风险，可设置 ALLOW_RUNTIME_CONNECTION_CONFIG=true 后热更新。
