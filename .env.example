# 服务器配置
FLASK_APP=main.py
FLASK_ENV=development
HOST=0.0.0.0
PORT=8000

# 调试模式（development 时自动启用）
# FLASK_ENV=development  # 开发模式（DEBUG=true）
# FLASK_ENV=production   # 生产模式（DEBUG=false）

# 数据库配置
DATABASE_URL=postgresql://username:password@localhost:5432/webhooks
# 数据库连接池配置
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30

# Webhook 安全配置
WEBHOOK_SECRET=your-secret-key-here

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/webhook.log

# 数据存储配置
DATA_DIR=webhooks_data
# 是否启用文件备份（除数据库外额外保存到文件）
ENABLE_FILE_BACKUP=false

# AI 分析和转发配置
ENABLE_AI_ANALYSIS=true
ENABLE_FORWARD=true
FORWARD_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_KEY

# OpenAI API 配置
OPENAI_API_KEY=sk-or-v1-xxxxx
OPENAI_API_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=anthropic/claude-sonnet-4
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=1800
OPENAI_TRUNCATION_RETRY_MAX_TOKENS=2600

# AI 提示词配置
# System Prompt - AI 的角色设定
AI_SYSTEM_PROMPT=你是一个专业的 DevOps 和系统运维专家，擅长分析 webhook 事件并提供准确的运维建议。你的职责是：1. 快速识别事件类型和严重程度 2. 提供清晰的问题摘要 3. 给出可执行的处理建议 4. 识别潜在风险和影响范围 5. 建议监控和预防措施

# User Prompt - 用户输入模板配置（二选一）
# 方式1：从文件加载（推荐）- 相对路径或绝对路径
# 可选模板：
#   - prompts/webhook_analysis.txt (默认通用版)
#   - prompts/webhook_analysis_simple.txt (简化版)
#   - prompts/webhook_analysis_detailed.txt (详细版，推荐生产环境)
AI_USER_PROMPT_FILE=prompts/webhook_analysis_detailed.txt
# 方式2：直接设置内容（优先级更高，设置后会忽略文件）
# AI_USER_PROMPT=请分析以下 webhook 事件...

# ============================================================
# 重复告警去重配置
# ============================================================

# 去重时间窗口（小时）
# 在此时间内相同告警视为重复，默认 24 小时
# 取值范围：1-168（7天）
DUPLICATE_ALERT_TIME_WINDOW=24

# 【窗口内】重复告警是否转发
# true: 窗口内的重复告警也会转发（不推荐，会导致通知轰炸）
# false: 窗口内的重复告警不转发（推荐）
FORWARD_DUPLICATE_ALERTS=false

# ============================================================
# 超时间窗口后的行为配置（新增）
# ============================================================
# 说明：当告警超过时间窗口后再次出现，如何处理？

# 是否重新调用 AI 分析
# true: 重新分析，确保结果最新（会产生 AI API 费用）
# false: 复用历史分析结果（节省 AI API 费用，推荐）
# 场景：
#   - 告警内容可能变化 → 设置 true
#   - 告警内容固定 → 设置 false 节省费用
REANALYZE_AFTER_TIME_WINDOW=true

# 是否推送转发（高风险告警）
# true: 定期提醒持续问题（例如每24小时提醒一次）
# false: 不推送，避免重复通知
# 场景：
#   - 需要定期关注持续问题 → 设置 true
#   - 避免通知疲劳 → 设置 false
FORWARD_AFTER_TIME_WINDOW=true

# ============================================================
# 配置组合建议
# ============================================================
# 场景1 - 成本敏感（推荐生产环境）：
#   REANALYZE_AFTER_TIME_WINDOW=false  # 节省 AI 费用
#   FORWARD_AFTER_TIME_WINDOW=true     # 但仍然提醒
#
# 场景2 - 准确性优先：
#   REANALYZE_AFTER_TIME_WINDOW=true   # 最新分析
#   FORWARD_AFTER_TIME_WINDOW=true     # 定期提醒
#
# 场景3 - 静默模式（已知持续问题）：
#   REANALYZE_AFTER_TIME_WINDOW=false  # 节省费用
#   FORWARD_AFTER_TIME_WINDOW=false    # 避免通知
#
# 场景4 - 仅记录不通知：
#   REANALYZE_AFTER_TIME_WINDOW=true   # 保持分析最新
#   FORWARD_AFTER_TIME_WINDOW=false    # 不推送
# ============================================================

# ============================================================
# 周期性提醒配置（新增）
# ============================================================
# 说明：即使在窗口内，长时间持续的告警也需要周期性提醒
#       防止"告警持续30小时但只通知1次"的问题

# 是否启用周期性提醒
# true: 启用周期性提醒（推荐）
# false: 禁用，窗口内重复告警不会再次通知
# 场景：
#   - 防止长期问题被忽略 → 设置 true（推荐）
#   - 避免通知频繁 → 设置 false
ENABLE_PERIODIC_REMINDER=true

# 周期性提醒间隔（小时）
# 在窗口内，如果告警持续重复，每隔此时间提醒一次
# 推荐值：6（每6小时提醒一次）
# 取值范围：1-24
# 场景：
#   - 关键告警 → 设置 1-3（频繁提醒）
#   - 一般告警 → 设置 6-12（适中）
#   - 低优先级 → 设置 24（每天提醒一次）
REMINDER_INTERVAL_HOURS=6

# ============================================================
# 周期性提醒配置组合建议
# ============================================================
# 场景1 - 关键系统（推荐）：
#   ENABLE_PERIODIC_REMINDER=true
#   REMINDER_INTERVAL_HOURS=6     # 每6小时提醒
#
# 场景2 - 频繁告警系统：
#   ENABLE_PERIODIC_REMINDER=true
#   REMINDER_INTERVAL_HOURS=12    # 每12小时提醒，避免疲劳
#
# 场景3 - 低优先级系统：
#   ENABLE_PERIODIC_REMINDER=true
#   REMINDER_INTERVAL_HOURS=24    # 每天提醒一次
#
# 场景4 - 仅首次通知：
#   ENABLE_PERIODIC_REMINDER=false # 禁用周期性提醒
# ============================================================

# ============================================================
# 并发控制与通知冷却配置（秒）
# ============================================================
# 处理同一告警时的分布式锁 TTL
PROCESSING_LOCK_TTL_SECONDS=120
# 获取处理锁的最大等待时间
PROCESSING_LOCK_WAIT_SECONDS=3
# 超窗口复用历史事件的短期窗口
RECENT_BEYOND_WINDOW_REUSE_SECONDS=30
# 同一告警再次通知的最小间隔
NOTIFICATION_COOLDOWN_SECONDS=60

# ============================================================
# 保存重试配置
# ============================================================
# 保存 webhook 到数据库失败时的最大重试次数
SAVE_MAX_RETRIES=3
# 每次重试前的等待时间（秒）
SAVE_RETRY_DELAY_SECONDS=0.1
# 重试间隔递增系数（指数退避）
# 第1次: 0.1s, 第2次: 0.2s, 第3次: 0.3s

# ============================================================
# 告警智能降噪 + 根因分析
# ============================================================
# 是否启用智能降噪与根因关联
ENABLE_ALERT_NOISE_REDUCTION=true
# 关联分析时间窗口（分钟）
NOISE_REDUCTION_WINDOW_MINUTES=5
# 判定"衍生告警"的最小置信度（0-1）
ROOT_CAUSE_MIN_CONFIDENCE=0.65
# 衍生告警是否默认抑制转发
SUPPRESS_DERIVED_ALERT_FORWARD=true

# ============================================================
# AIOps 升级配置
# ============================================================

# AI 成本优化
CACHE_ENABLED=true
# 分析结果缓存 TTL（秒），默认 6 小时
ANALYSIS_CACHE_TTL=21600
# 智能路由（根据告警复杂度选择 AI/规则/缓存）
SMART_ROUTING_ENABLED=true
# AI 成本估算（美元/1K tokens）
AI_COST_PER_1K_INPUT_TOKENS=0.003
AI_COST_PER_1K_OUTPUT_TOKENS=0.015

# ============================================================
# OpenOcta 深度分析引擎
# ============================================================
# 是否启用 OpenOcta 深度分析
OPENOCTA_ENABLED=true
# OpenOcta Gateway 地址
OPENOCTA_GATEWAY_URL=http://127.0.0.1:18900
# OpenOcta Gateway Token
OPENOCTA_GATEWAY_TOKEN=your-openocta-token-here
# OpenOcta Hooks Token（用于 hooks 端点认证）
OPENOCTA_HOOKS_TOKEN=
# OpenOcta 请求超时（秒）
OPENOCTA_TIMEOUT_SECONDS=300
# 深度分析引擎选择: local | openocta | auto
# local: 仅使用本地 AI
# openocta: 优先使用 OpenOcta
# auto: 根据配置自动选择（推荐）
DEEP_ANALYSIS_ENGINE=auto

# OpenOcta WebSocket 连接超时配置（秒）
OPENOCTA_CONNECT_TIMEOUT=10     # TCP + WS 握手超时
OPENOCTA_HANDSHAKE_TIMEOUT=5    # OpenOcta 协议握手超时
OPENOCTA_RECV_TIMEOUT=1.0       # recv 超时（检查 _done 事件）
OPENOCTA_NONCE_TIMEOUT=2.0      # 接收 nonce challenge 超时
OPENOCTA_POLL_TIMEOUT=90        # 轮询结果超时（高延迟网络适配）

# OpenOcta/OpenClaw 轮询稳定性参数
OPENCLAW_STABILITY_REQUIRED_HITS=2      # 连续 N 次一致才确认完成
OPENCLAW_MIN_WAIT_SECONDS=30          # 创建后最少等待秒数再开始轮询
OPENCLAW_MAX_CONSECUTIVE_ERRORS=5      # 连续超时最大次数，超过则降级使用首次结果

# 深度分析完成后发送飞书通知（可选）
# 如果为空则不通知
DEEP_ANALYSIS_FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/0b520b7f-887c-4f89-a0b7-737e98404894

# ============================================================
# HTTP 请求超时配置（秒）
# ============================================================
AI_API_TIMEOUT=10              # AI API 请求超时
FEISHU_WEBHOOK_TIMEOUT=10       # 飞书 webhook 请求超时
FORWARD_TIMEOUT=10              # 转发请求超时

# ============================================================
# OpenClaw 设备认证（可选，用于 chat.history 等 operator 级别操作）
# ============================================================
#
# 获取方式：在 OpenClaw 服务器上执行以下命令获取对应值
#
# 1. OPENCLAW_DEVICE_ID 和 OPENCLAW_DEVICE_PRIVATE_KEY_PEM:
#    cat ~/.openclaw/identity/device.json
#    - OPENCLAW_DEVICE_ID = deviceId 字段
#    - OPENCLAW_DEVICE_PRIVATE_KEY_PEM = privateKeyPem 中 base64 内容
#      （去掉 -----BEGIN/END PRIVATE KEY----- 头尾和换行，只保留中间部分）
#
# 2. OPENCLAW_DEVICE_TOKEN:
#    cat ~/.openclaw/identity/device-auth.json
#    - OPENCLAW_DEVICE_TOKEN = tokens.operator.token 字段
#
# 注意：这些值由 OpenClaw CLI 首次运行时自动生成的 Ed25519 密钥对派生。
#       如果服务器上还没有这些文件，先运行一次 openclaw 命令即可自动生成。
#       device.json 中的 privateKeyPem 是该设备的唯一身份私钥，请妥善保管。
#
OPENCLAW_DEVICE_ID=
OPENCLAW_DEVICE_PRIVATE_KEY_PEM=
OPENCLAW_DEVICE_TOKEN=

